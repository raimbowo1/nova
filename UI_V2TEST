        local resizeHandle = create("TextButton", {
            Parent = root, AnchorPoint = Vector2.new(1,1), Position = UDim2.new(1,0,1,0),
            Size = UDim2.new(0,20,0,20), BackgroundTransparency = 1,
            Text = "◢", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Muted, TextSize = 12, ZIndex = 5
        })
        makeResizable(resizeHandle, shadow, Vector2.new(480, 340))
        connect(resizeHandle.MouseEnter, function() animate(resizeHandle, TweenInfo.new(0.2), {TextColor3 = self.Theme.Accent}) end)
        connect(resizeHandle.MouseLeave, function() animate(resizeHandle, TweenInfo.new(0.2), {TextColor3 = self.Theme.Muted}) end)
    end

    -- Toggle button
    if cfg.UseToggleButton ~= false then
        local btn = create("TextButton", {Parent = gui, Size = UDim2.new(0,48,0,48), Position = UDim2.new(0,20,0.5,0), AnchorPoint = Vector2.new(0,0.5), BackgroundColor3 = self.Theme.Surface, Text = cfg.ToggleButtonText or "UI", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 13, BackgroundTransparency = 1, TextTransparency = 1, Visible = false})
        create("UIScale", {Parent = btn, Scale = 0})
        applyCorner(btn, 24); local glowStroke = applyStroke(btn, self.Theme.Accent, 2, 1); trackTheme("Accent", glowStroke, "Color")
        task.spawn(function()
            while true do
                if self.Hidden then animate(glowStroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.2}) else glowStroke.Transparency = 1 end
                task.wait(1.4)
                if self.Hidden then animate(glowStroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.85}) else glowStroke.Transparency = 1 end
                task.wait(1.4)
            end
        end)
        connect(btn.MouseButton1Click, function() NovaUI:Toggle() end)
        makeDraggable(btn, btn)
        self.ToggleButton = btn
    end

    self.MainFrame = shadow; self.MainScale = scaleObj
    self.CurrentWindow = {Root = root, Sidebar = sidebar, Content = contentHolder, Shadow = shadow, DefaultSize = defaultSize, Tabs = thisWindowTabs, SelectedTab = nil, TitleLabel = titleLbl, ConfigName = cfg.ConfigName or "default"}
    setmetatable(self.CurrentWindow, {__index = WindowMethods})
    return self.CurrentWindow
end

