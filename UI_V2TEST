        Min = 0,
        Max = 0.5,
        Increment = 0.01,
        Default = NovaUI.Theme.PanelTransparency,
        Callback = function(v) NovaUI:SetTheme({PanelTransparency = v}) end
    })
    themeSection:AddSlider({
        Name = "Section Transparency",
        Min = 0,
        Max = 0.65,
        Increment = 0.01,
        Default = NovaUI.Theme.SectionTransparency,
        Callback = function(v) NovaUI:SetTheme({SectionTransparency = v}) end
    })
    themeSection:AddSlider({
        Name = "Item Transparency",
        Min = 0,
        Max = 0.75,
        Increment = 0.01,
        Default = NovaUI.Theme.ItemTransparency,
        Callback = function(v) NovaUI:SetTheme({ItemTransparency = v}) end
    })

    -- Config section
    if NovaUI.SaveConfig then
        local cfgSection = tab:CreateSection({Name = "Config Profiles"})
        local profileBox = {Get = function() return "default" end}

        local profInput = cfgSection:AddTextbox({
            Name = "Profile Name",
            Placeholder = "default",
            Default = "default",
        })

        cfgSection:AddButton({
            Name = "💾  Save Profile",
            Callback = function() self:SaveConfig(profInput.Get()) end
        })
        cfgSection:AddButton({
            Name = "📂  Load Profile",
            Callback = function() self:LoadConfig(profInput.Get()) end
