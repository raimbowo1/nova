    local chartArea = create("Frame", {Parent = row, Position = UDim2.new(0,12,0,28), Size = UDim2.new(1,-24,0,h), BackgroundColor3 = NovaUI.Theme.Surface}); applyCorner(chartArea, 6)
    local barHolder = create("Frame", {Parent = chartArea, BackgroundTransparency = 1, Size = UDim2.new(1,-8,1,-4), Position = UDim2.new(0,4,0,2)})
    local ll = create("UIListLayout", {Parent = barHolder, FillDirection = Enum.FillDirection.Horizontal, VerticalAlignment = Enum.VerticalAlignment.Bottom, Padding = UDim.new(0,3), SortOrder = Enum.SortOrder.LayoutOrder})

    local barFrames = {}

    local function renderBars()
        for _, b in ipairs(barFrames) do b:Destroy() end; barFrames = {}
        local count = math.max(1, #values)
        for i, val in ipairs(values) do
            local pct = math.clamp(val / maxVal, 0, 1)
            local barWrap = create("Frame", {Parent = barHolder, LayoutOrder = i, Size = UDim2.new(1/count, -3, 1, 0), BackgroundTransparency = 1})
            local bar = create("Frame", {Parent = barWrap, AnchorPoint = Vector2.new(0,1), Position = UDim2.new(0,0,1,0), Size = UDim2.new(1,0,0,2), BackgroundColor3 = NovaUI.Theme.Accent}); applyCorner(bar, 3); trackTheme("Accent", bar, "BackgroundColor3")
            animate(bar, TweenInfo.new(0.5, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(1,0,pct,0)})
            if labels[i] then
                create("TextLabel", {Parent = barWrap, Position = UDim2.new(0,0,1,2), Size = UDim2.new(1,0,0,12), BackgroundTransparency = 1, Text = tostring(labels[i]), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 9, TextXAlignment = Enum.TextXAlignment.Center})
            end
            table.insert(barFrames, barWrap)
        end
    end

    renderBars()
    return NovaUI:RegisterElement({Update = function(newVals, newMax) values = newVals or values; if newMax then maxVal = newMax end; renderBars() end}, cfg.Name, row)
end

-- NEW: Data Table
function SectionMethods:AddTable(cfg)
    local columns = cfg.Columns or {}
    local data = cfg.Data or {}
    local sortCol = nil
    local sortAsc = true
    local filter = ""

    local containerH = cfg.Height or 160
    local row = makeRow(self.Holder, 0); row.AutomaticSize = Enum.AutomaticSize.None; row.Size = UDim2.new(1,0,0,containerH + 46)
    applyTooltip(row, cfg.Tooltip)

    create("TextLabel", {Parent = row, Position = UDim2.new(0,12,0,6), Size = UDim2.new(0.6,0,0,16), BackgroundTransparency = 1, Text = cfg.Name or "Table", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})

    -- Optional search box
    if cfg.Searchable then
        local sb = create("TextBox", {Parent = row, Position = UDim2.new(1,-140,0,4), Size = UDim2.new(0,128,0,22), BackgroundColor3 = NovaUI.Theme.Surface, Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Text, PlaceholderText = "Filter...", PlaceholderColor3 = NovaUI.Theme.Muted, TextSize = 11, Text = ""}); applyCorner(sb, 4); applyStroke(sb, NovaUI.Theme.Stroke, 1, 0.5)
        connect(sb.Changed, function() filter = sb.Text:lower(); renderTable() end)
    end

    local tableFrame = create("ScrollingFrame", {Parent = row, Position = UDim2.new(0,6,0,30), Size = UDim2.new(1,-12,0,containerH), BackgroundColor3 = NovaUI.Theme.Surface, ScrollBarThickness = 2, ScrollBarImageColor3 = NovaUI.Theme.Accent, AutomaticCanvasSize = Enum.AutomaticSize.Y}); applyCorner(tableFrame, 6); trackTheme("Accent", tableFrame, "ScrollBarImageColor3")

    -- Header
    local headerRow = create("Frame", {Parent = tableFrame, Size = UDim2.new(1,0,0,26), BackgroundColor3 = NovaUI.Theme.Background, LayoutOrder = 0}); applyCorner(headerRow, 6)
    local colW = 1 / math.max(1, #columns)
    local sortBtns = {}
    for ci, col in ipairs(columns) do
        local hBtn = create("TextButton", {Parent = headerRow, Position = UDim2.new((ci-1)*colW,2,0,0), Size = UDim2.new(colW,-4,1,0), BackgroundTransparency = 1, Text = col.." ↕", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left})
        create("UIPadding", {Parent = hBtn, PaddingLeft = UDim.new(0,4)})
        table.insert(sortBtns, hBtn)
        connect(hBtn.MouseButton1Click, function()
            if sortCol == ci then sortAsc = not sortAsc else sortCol = ci; sortAsc = true end
            renderTable()
        end)
    end
    create("UIListLayout", {Parent = tableFrame, Padding = UDim.new(0,1), SortOrder = Enum.SortOrder.LayoutOrder})

    local rowObjs = {}
    function renderTable()
        for _, r in ipairs(rowObjs) do r:Destroy() end; rowObjs = {}
        local filtered = {}
        for _, dataRow in ipairs(data) do
            if filter == "" then table.insert(filtered, dataRow)
            else
                for _, cell in ipairs(dataRow) do
                    if string.find(tostring(cell):lower(), filter, 1, true) then table.insert(filtered, dataRow); break end
                end
            end
        end
        if sortCol then
            table.sort(filtered, function(a, b)
                local av, bv = tostring(a[sortCol] or ""), tostring(b[sortCol] or "")
                local an, bn = tonumber(av), tonumber(bv)
                if an and bn then return sortAsc and an < bn or an > bn end
                return sortAsc and av < bv or av > bv
            end)
        end
        for ri, dataRow in ipairs(filtered) do
            local dr = create("Frame", {Parent = tableFrame, Size = UDim2.new(1,0,0,26), BackgroundColor3 = ri % 2 == 0 and NovaUI.Theme.Background or NovaUI.Theme.Surface, LayoutOrder = ri})
            for ci, cell in ipairs(dataRow) do
                create("TextLabel", {Parent = dr, Position = UDim2.new((ci-1)*colW,2,0,0), Size = UDim2.new(colW,-4,1,0), BackgroundTransparency = 1, Text = tostring(cell), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Text, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left})
            end
            table.insert(rowObjs, dr)
        end
        -- Update sort indicators
        for ci, hBtn in ipairs(sortBtns) do
            hBtn.Text = columns[ci] .. (sortCol == ci and (sortAsc and " ↑" or " ↓") or " ↕")
        end
    end
    renderTable()

    return NovaUI:RegisterElement({SetData = function(d) data = d or {}; renderTable() end, GetData = function() return data end}, cfg.Name, row)
end

