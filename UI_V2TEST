    local tab = self:CreateTab({Name = "Settings", Icon = "⚙️"})

    -- Theme section
    local themeSection = tab:CreateSection({Name = "Theme"})

    local presetNames = {}
    for k in pairs(NovaUI.Presets) do table.insert(presetNames, k) end

    themeSection:AddDropdown({
        Name = "Preset",
        Options = presetNames,
        Default = "Dark",
        Callback = function(v) NovaUI:SetTheme(v) end
    })
    themeSection:AddColorPicker({
