    local box = create("Frame", {Parent = row, Position = UDim2.new(1,-54,0.5,-12), Size = UDim2.new(0,42,0,24), BackgroundColor3 = NovaUI.Theme.Background})
    applyCorner(box, 12); applyStroke(box, NovaUI.Theme.Stroke, 1)
    local knob = create("Frame", {Parent = box, Position = UDim2.new(0,2,0.5,-10), Size = UDim2.new(0,20,0,20), BackgroundColor3 = NovaUI.Theme.Text})
    applyCorner(knob, 10)
    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = ""})

    local state = cfg.Default or false
    local function setToggle(v, skipCallback)
        state = v
        animate(knob, TweenInfo.new(0.1), {Size = UDim2.new(0,26,0,18)})
        task.delay(0.1, function()
            animate(box, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.Background})
            animate(knob, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = state and UDim2.new(1,-22,0.5,-10) or UDim2.new(0,2,0.5,-10), Size = UDim2.new(0,20,0,20)})
        end)
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = state end
        NovaUI:CheckDependencies()
        if not skipCallback and cfg.Callback then task.spawn(cfg.Callback, state) end
    end

    connect(btn.MouseButton1Click, function() setToggle(not state) end)
    if cfg.ContextMenu then connect(btn.MouseButton2Click, function() NovaUI:ShowContextMenu(cfg.ContextMenu) end) end
    setToggle(state, true)
    table.insert(NovaUI.ThemeObjects.ToggleBoxes, {box, function() return state end})
    return NovaUI:RegisterElement({Set = setToggle, Get = function() return state end}, cfg.Name, row, cfg.Flag)
end

-- FIX: Slider - click value label to type exact number
function SectionMethods:AddSlider(cfg)
    local min, max, inc = cfg.Min or 0, cfg.Max or 100, cfg.Increment or 1
    local row = makeRow(self.Holder, 54)
    applyTooltip(row, cfg.Tooltip)
    local decimals = 0
    if inc < 1 then
        local fractional = tostring(inc):match("%.(%d+)")
        decimals = fractional and #fractional or 0
    end

    local function formatValue(v)
        if decimals > 0 then
            return string.format("%."..decimals.."f", v)
        end
        return tostring(math.floor(v + 0.5))
    end

    create("TextLabel", {Parent = row, Position = UDim2.new(0,12,0,8), Size = UDim2.new(1,-80,0,16), BackgroundTransparency = 1, Text = cfg.Name or "Slider", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    
    -- Clickable value label that becomes a textbox
    local valBox = create("TextBox", {Parent = row, Position = UDim2.new(1,-68,0,5), Size = UDim2.new(0,56,0,22), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0.6, Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 12, Text = formatValue(cfg.Default or min), TextXAlignment = Enum.TextXAlignment.Center, ClearTextOnFocus = true})
    applyCorner(valBox, 4); applyStroke(valBox, NovaUI.Theme.Stroke, 1, 0.7)

    local bar  = create("Frame", {Parent = row, Position = UDim2.new(0,12,0,36), Size = UDim2.new(1,-24,0,6), BackgroundColor3 = NovaUI.Theme.Surface}); applyCorner(bar, 3)
    local fill = create("Frame", {Parent = bar, Size = UDim2.new(0,0,1,0), BackgroundColor3 = NovaUI.Theme.Accent}); applyCorner(fill, 3); trackTheme("Accent", fill, "BackgroundColor3")
    local knob = create("Frame", {Parent = fill, AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(1,0,0.5,0), Size = UDim2.new(0,14,0,14), BackgroundColor3 = NovaUI.Theme.Text}); applyCorner(knob, 7)

    local currentVal = cfg.Default or min
    local function setVal(v, skip)
        v = math.clamp(math.floor(v / inc + 0.5) * inc, min, max)
        currentVal = v
        animate(fill, TweenInfo.new(0.1), {Size = UDim2.new((v - min) / (max - min), 0, 1, 0)})
        valBox.Text = formatValue(v) .. (cfg.ValueName or "")
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = v end
        if not skip and cfg.Callback then task.spawn(cfg.Callback, v) end
    end

    -- Textbox input
    connect(valBox.FocusLost, function()
        local n = tonumber(valBox.Text)
        if n then setVal(n) else valBox.Text = formatValue(currentVal) .. (cfg.ValueName or "") end
        animate(valBox.UIStroke, TweenInfo.new(0.2), {Transparency = 0.7, Color = NovaUI.Theme.Stroke})
    end)
    connect(valBox.Focused, function()
        valBox.Text = formatValue(currentVal)
        animate(valBox.UIStroke, TweenInfo.new(0.2), {Transparency = 0, Color = NovaUI.Theme.Accent})
    end)

    local dragging = false
    local hitBox = create("TextButton", {Parent = row, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = ""})
    -- Don't capture the valBox area
    connect(hitBox.InputBegan, function(inp)
        if inp.UserInputType.Name:find("MouseButton1") then
            -- ignore if over valBox
            local mp = UserInputService:GetMouseLocation()
            local abs = valBox.AbsolutePosition; local sz = valBox.AbsoluteSize
            if mp.X >= abs.X and mp.X <= abs.X + sz.X and mp.Y >= abs.Y and mp.Y <= abs.Y + sz.Y then return end
            dragging = true
            animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0,18,0,18)})
            setVal(min + math.clamp((inp.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1) * (max - min))
        end
    end)
    connect(hitBox.InputEnded, function(inp)
        if inp.UserInputType.Name:find("MouseButton1") then dragging = false; animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0,14,0,14)}) end
    end)
    connect(UserInputService.InputChanged, function(inp)
        if dragging and inp.UserInputType.Name:find("MouseMovement") then
            setVal(min + math.clamp((inp.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1) * (max - min))
        end
    end)

    -- Right-click to reset
    connect(hitBox.MouseButton2Click, function() setVal(cfg.Default or min) end)

    setVal(cfg.Default or min, true)
    return NovaUI:RegisterElement({Set = setVal, Get = function() return currentVal end}, cfg.Name, row, cfg.Flag)
end

function SectionMethods:AddProgressBar(cfg)
    local min, max = cfg.Min or 0, cfg.Max or 100
