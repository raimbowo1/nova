-- ─── Helpers ────────────────────────────────────────────────────────────────

local function connect(signal, fn)
    local c = signal:Connect(fn)
    table.insert(NovaUI.Connections, c)
    return c
end

local function create(className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do obj[k] = v end
    return obj
end

local function applyCorner(parent, radius)
    return create("UICorner", {CornerRadius = UDim.new(0, radius or 8), Parent = parent})
end

local function applyStroke(parent, color, thickness, alpha)
    return create("UIStroke", {Color = color or NovaUI.Theme.Stroke, Thickness = thickness or 1, Transparency = alpha or 0, Parent = parent})
end

local function safeParentGui()
    local ok, res = pcall(function()
        if gethui then return gethui() end
        if cloneref then return cloneref(CoreGui) end
        return CoreGui
    end)
    return (ok and res) or LocalPlayer:FindFirstChild("PlayerGui") or CoreGui
end

local function makeDraggable(handle, target)
    local dragging, dragInput, startPos, startFramePos = false, nil, nil, nil
    connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; startPos = input.Position; startFramePos = target.Position
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
        end
    end)
    connect(handle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    connect(UserInputService.InputChanged, function(input)
        if dragging and input == dragInput then
            target.Position = UDim2.new(
                startFramePos.X.Scale, startFramePos.X.Offset + (input.Position.X - startPos.X),
                startFramePos.Y.Scale, startFramePos.Y.Offset + (input.Position.Y - startPos.Y))
        end
    end)
end

-- FIX: corrected resize direction (drag bottom-right corner outward = bigger)
local function makeResizable(handle, target, minSize)
    local resizing, dragInput, startPos, startSize = false, nil, nil, nil
    connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            resizing = true; startPos = input.Position; startSize = target.Size
            input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then resizing = false end end)
        end
    end)
    connect(handle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    connect(UserInputService.InputChanged, function(input)
        if resizing and input == dragInput then
            local vp = workspace.CurrentCamera.ViewportSize
            local delta = input.Position - startPos
            local newW = math.clamp(startSize.X.Offset + delta.X, minSize.X, vp.X * 0.95)
            local newH = math.clamp(startSize.Y.Offset + delta.Y, minSize.Y, vp.Y * 0.95)
            target.Size = UDim2.new(0, newW, 0, newH)
        end
    end)
end

local function animate(obj, info, props)
    local tw = TweenService:Create(obj, info, props); tw:Play(); return tw
end

local function trackTheme(key, obj, prop)
    if NovaUI.ThemeObjects[key] then
        table.insert(NovaUI.ThemeObjects[key], {obj, prop})
    end
end

local function applyTooltip(row, tooltipText)
    if tooltipText then
        connect(row.MouseEnter, function() NovaUI:ShowTooltip(tooltipText) end)
        connect(row.MouseLeave, function() NovaUI:HideTooltip() end)
    end
end

local function makeRow(parent, h)
    local r = create("Frame", {Parent = parent, Size = UDim2.new(1, 0, 0, h), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = NovaUI.Theme.ItemTransparency})
    applyCorner(r, 10)
    local stroke = applyStroke(r, NovaUI.Theme.Stroke, 1, 0.6)
    trackTheme("Surface", r, "BackgroundColor3")
    trackTheme("ItemTransparency", r, "BackgroundTransparency")
    trackTheme("Stroke", stroke, "Color")
    return r
end

-- ─── Core Init ──────────────────────────────────────────────────────────────

function NovaUI:_ensureGui()
    if self.ScreenGui and self.ScreenGui.Parent then return self.ScreenGui end
    local gui = create("ScreenGui", {Name = "NovaUI", ResetOnSpawn = false, IgnoreGuiInset = true, ZIndexBehavior = Enum.ZIndexBehavior.Global})
    local target = safeParentGui()
    for _, child in ipairs(target:GetChildren()) do
        if child.Name == gui.Name then pcall(function() child:Destroy() end) end
    end
    gui.Parent = target
    self.ScreenGui = gui

    -- Tooltip
    self.TooltipFrame = create("Frame", {Parent = gui, Size = UDim2.new(0, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.XY, BackgroundColor3 = Color3.fromRGB(15,15,20), BackgroundTransparency = 1, ZIndex = 100, Visible = false})
    applyCorner(self.TooltipFrame, 6)
    self.TooltipStroke = applyStroke(self.TooltipFrame, self.Theme.Accent, 1, 1)
    create("UIPadding", {Parent = self.TooltipFrame, PaddingLeft = UDim.new(0,8), PaddingRight = UDim.new(0,8), PaddingTop = UDim.new(0,6), PaddingBottom = UDim.new(0,6)})
    self.TooltipLabel = create("TextLabel", {Parent = self.TooltipFrame, Size = UDim2.new(0,0,0,14), AutomaticSize = Enum.AutomaticSize.X, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextColor3 = self.Theme.Text, TextSize = 12, TextTransparency = 1})

    -- FIX: Heartbeat gated when no tooltip active
    connect(RunService.Heartbeat, function()
        if self.ActiveTooltip and self.TooltipFrame.Visible then
            local mp = UserInputService:GetMouseLocation()
            self.TooltipFrame.Position = UDim2.new(0, mp.X + 15, 0, mp.Y - 15)
        end
    end)

    return gui
end

function NovaUI:ShowTooltip(text)
    self.ActiveTooltip = text
    self.TooltipLabel.Text = text
    self.TooltipFrame.Visible = true
    animate(self.TooltipFrame,  TweenInfo.new(0.2), {BackgroundTransparency = 0})
    animate(self.TooltipStroke, TweenInfo.new(0.2), {Transparency = 0.5})
    animate(self.TooltipLabel,  TweenInfo.new(0.2), {TextTransparency = 0})
end

function NovaUI:HideTooltip()
    self.ActiveTooltip = nil
    animate(self.TooltipFrame,  TweenInfo.new(0.15), {BackgroundTransparency = 1})
    animate(self.TooltipStroke, TweenInfo.new(0.15), {Transparency = 1})
    animate(self.TooltipLabel,  TweenInfo.new(0.15), {TextTransparency = 1}).Completed:Connect(function()
        if not self.ActiveTooltip then self.TooltipFrame.Visible = false end
    end)
end

-- ─── Element Registry ────────────────────────────────────────────────────────

function NovaUI:RegisterElement(obj, name, row, flagName)
    table.insert(self.Elements, {Obj = obj, Name = name:lower(), Row = row, Visible = true, Deps = {}, Flag = flagName})
    local ref = self.Elements[#self.Elements]

    obj.DependOn = function(fName, expectedValue)
        table.insert(ref.Deps, {Flag = fName, Value = expectedValue})
        obj.ApplyDeps()
    end
    obj.ApplyDeps = function()
        local shouldShow = true
        for _, dep in ipairs(ref.Deps) do
            if NovaUI.Flags[dep.Flag] ~= dep.Value then shouldShow = false; break end
        end
        ref.Row.Visible = (ref.Visible and shouldShow)
    end
    return obj
end

-- NEW: retrieve element by flag name
function NovaUI:GetElement(flagName)
    for _, e in ipairs(self.Elements) do
        if e.Flag == flagName then return e.Obj end
    end
    return nil
end

function NovaUI:CheckDependencies()
    for _, e in ipairs(self.Elements) do if e.Obj.ApplyDeps then e.Obj.ApplyDeps() end end
end

-- ─── Theme ───────────────────────────────────────────────────────────────────

function NovaUI:SetTheme(patch)
    if type(patch) == "string" and self.Presets[patch] then patch = self.Presets[patch] end
    if type(patch) ~= "table" then return end
    for k, v in pairs(patch) do
        if self.Theme[k] ~= nil then
            self.Theme[k] = v
            if self.ThemeObjects[k] then
                for _, entry in ipairs(self.ThemeObjects[k]) do
                    pcall(function()
                        if entry[2] == "ScrollBarImageColor3" or entry[2] == "ImageColor3" then
                            entry[1][entry[2]] = v
                        else
                            animate(entry[1], TweenInfo.new(0.4), {[entry[2]] = v})
                        end
                    end)
                end
            end
            if k == "Accent" then
                for _, entry in ipairs(self.ThemeObjects.ToggleBoxes) do
                    if entry[1].Parent and entry[2]() then
                        animate(entry[1], TweenInfo.new(0.4), {BackgroundColor3 = v})
                    end
                end
            end
        end
    end
    if patch.Accent then self.TooltipStroke.Color = patch.Accent end
end

function NovaUI:SetAccent(color) self:SetTheme({Accent = color}) end

-- ─── Visibility ──────────────────────────────────────────────────────────────

function NovaUI:Toggle(force)
    if not self.MainScale then return end
    self.Hidden = (force ~= nil) and (not force) or (not self.Hidden)
    local tInfo = TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out)
    animate(self.MainScale, tInfo, {Scale = self.Hidden and 0 or 1})

    if self.ToggleButton then
        local btnScale = self.ToggleButton:FindFirstChildOfClass("UIScale")
        if self.Hidden then
            self.ToggleButton.Visible = true
            animate(self.ToggleButton, tInfo, {BackgroundTransparency = self.Theme.ItemTransparency, TextTransparency = 0})
            if btnScale then animate(btnScale, tInfo, {Scale = 1}) end
            if self.ToggleButton:FindFirstChildOfClass("UIStroke") then animate(self.ToggleButton:FindFirstChildOfClass("UIStroke"), tInfo, {Transparency = 0.5}) end
        else
            animate(self.ToggleButton, tInfo, {BackgroundTransparency = 1, TextTransparency = 1})
            if btnScale then animate(btnScale, tInfo, {Scale = 0}) end
            if self.ToggleButton:FindFirstChildOfClass("UIStroke") then animate(self.ToggleButton:FindFirstChildOfClass("UIStroke"), tInfo, {Transparency = 1}) end
            task.delay(0.4, function() if not self.Hidden then self.ToggleButton.Visible = false end end)
        end
    end
end

function NovaUI:Init()
    if self.MainScale then
        self.Hidden = false
        animate(self.MainScale, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
        if self.MainFrame then animate(self.MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {ImageTransparency = 0.5}) end
    end
end

-- NEW: Full teardown
function NovaUI:Destroy()
    for _, c in ipairs(self.Connections) do pcall(function() c:Disconnect() end) end
    self.Connections = {}
    self.Elements = {}
    self.Flags = {}
    self.Notifications = {}
    self.ThemeObjects = {Accent={}, Text={}, Muted={}, Surface={}, Background={}, Stroke={}, Success={}, Danger={}, WindowTransparency={}, PanelTransparency={}, SectionTransparency={}, ItemTransparency={}, ToggleBoxes={}}
    if self.ScreenGui then pcall(function() self.ScreenGui:Destroy() end) end
    self.ScreenGui = nil; self.MainFrame = nil; self.MainScale = nil
    self.CurrentWindow = nil; self.ToggleButton = nil
    self.ActiveTooltip = nil; self.Hidden = false
end

