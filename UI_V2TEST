    local buttons = {}
    local function refreshRadios()
        for opt, b in pairs(buttons) do
            local isSel = (opt == selected)
            animate(b.Outer, TweenInfo.new(0.2), {BackgroundColor3 = isSel and NovaUI.Theme.Accent or NovaUI.Theme.Background})
            b.Inner.Visible = isSel
        end
    end

    for i, opt in ipairs(options) do
        local optRow = create("Frame", {Parent = row, LayoutOrder = i, Size = UDim2.new(1,0,0,24), BackgroundTransparency = 1})
        local outer = create("Frame", {Parent = optRow, Position = UDim2.new(0,0,0.5,-9), Size = UDim2.new(0,18,0,18), BackgroundColor3 = NovaUI.Theme.Background}); applyCorner(outer, 9); applyStroke(outer, NovaUI.Theme.Accent, 1, 0.3)
        local inner = create("Frame", {Parent = outer, AnchorPoint = Vector2.new(0.5,0.5), Position = UDim2.new(0.5,0,0.5,0), Size = UDim2.new(0,10,0,10), BackgroundColor3 = NovaUI.Theme.Accent, Visible = false}); applyCorner(inner, 5); trackTheme("Accent", inner, "BackgroundColor3")
        create("TextLabel", {Parent = optRow, Position = UDim2.new(0,24,0,0), Size = UDim2.new(1,-24,1,0), BackgroundTransparency = 1, Text = tostring(opt), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Text, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left})
        local hitBtn = create("TextButton", {Parent = optRow, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = ""})
