    -- Sidebar collapse
    local sidebarOpen = true
    local function refreshWindowLayout()
        local activeSidebarWidth = sidebarOpen and sidebarExpandedWidth or sidebarCollapsedWidth
        local contentX = panelInset + activeSidebarWidth + panelGap
        animate(menuBtn, TweenInfo.new(0.3), {Rotation = sidebarOpen and 0 or 90})
        animate(sidebarShell, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, activeSidebarWidth, 1, -(contentTop + bottomInset))})
        animate(contentShell, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0, contentX, 0, contentTop), Size = UDim2.new(1, -(contentX + panelInset), 1, -(contentTop + bottomInset))})
        for _, tab in ipairs(thisWindowTabs) do
            if tab.LabelText then animate(tab.LabelText, TweenInfo.new(0.3), {TextTransparency = sidebarOpen and 0 or 1}) end
        end
    end

    connect(menuBtn.MouseButton1Click, function()
        sidebarOpen = not sidebarOpen
        refreshWindowLayout()
    end)

    -- Minimize
    local minimized = false
    connect(minBtn.MouseButton1Click, function()
        minimized = not minimized
        animate(shadow, TweenInfo.new(0.4, Enum.EasingStyle.Exponential), {Size = minimized and UDim2.new(0, defaultSizeX, 0, topbarHeight) + UDim2.new(0,40,0,40) or defaultSize + UDim2.new(0,40,0,40)})
        contentShell.Visible = not minimized; sidebarShell.Visible = not minimized
    end)

    connect(closeBtn.MouseButton1Click, function() NovaUI:Toggle(false) end)

    -- FIX: resize handle at bottom-right corner, corrected delta math
