-- FIX: AddBind - keybind conflict detection + mode cycling
function SectionMethods:AddBind(cfg)
    local bound = cfg.Default or Enum.KeyCode.Unknown
    local mode = "Toggle"
    local row = makeRow(self.Holder, 42)
    applyTooltip(row, cfg.Tooltip)

    create("TextLabel", {Parent = row, Position = UDim2.new(0,12,0,0), Size = UDim2.new(0.5,0,1,0), BackgroundTransparency = 1, Text = cfg.Name or "Keybind", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local modeBtn = create("TextButton", {Parent = row, Position = UDim2.new(1,-144,0.5,-10), Size = UDim2.new(0,20,0,20), BackgroundTransparency = 1, Text = "⚙️", TextSize = 12})
    local btn = create("TextButton", {Parent = row, Position = UDim2.new(1,-112,0.5,-14), Size = UDim2.new(0,100,0,28), BackgroundColor3 = NovaUI.Theme.Surface, Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Accent, Text = bound.Name, TextSize = 12})
    applyCorner(btn, 6); applyStroke(btn, NovaUI.Theme.Stroke, 1, 0.5); trackTheme("Accent", btn, "TextColor3")

    local listening = false; local isActive = false

    local function checkConflict(key)
        for _, e in ipairs(NovaUI.Elements) do
            if e.Flag and e.Flag ~= cfg.Flag and NovaUI.Flags[e.Flag] == key.Name then
                NovaUI:Notify({Title = "Keybind Conflict", Content = '"'..key.Name..'" is already used by "'..e.Name..'"', Duration = 4})
                return true
            end
        end
        return false
    end

    connect(btn.MouseButton1Click, function()
        listening = true; btn.Text = "..."
        animate(btn.UIStroke, TweenInfo.new(0.2), {Color = NovaUI.Theme.Accent, Transparency = 0})
    end)
    connect(modeBtn.MouseButton1Click, function()
        if mode == "Toggle" then mode = "Hold" elseif mode == "Hold" then mode = "Always" else mode = "Toggle" end
        NovaUI:Notify({Title = "Keybind Mode", Content = (cfg.Name or "Bind").." set to "..mode, Duration = 2})
    end)
    connect(UserInputService.InputBegan, function(inp, gp)
        if listening and inp.KeyCode ~= Enum.KeyCode.Unknown then
            listening = false
            if not checkConflict(inp.KeyCode) then
                bound = inp.KeyCode; btn.Text = bound.Name
                animate(btn.UIStroke, TweenInfo.new(0.2), {Color = NovaUI.Theme.Stroke, Transparency = 0.5})
                if cfg.Flag then NovaUI.Flags[cfg.Flag] = bound.Name end
                if cfg.Callback then task.spawn(cfg.Callback, bound) end
            else
                btn.Text = bound.Name
                animate(btn.UIStroke, TweenInfo.new(0.2), {Color = NovaUI.Theme.Stroke, Transparency = 0.5})
            end
        elseif not listening and not gp then
            if mode == "Toggle" and inp.KeyCode == bound then isActive = not isActive; if cfg.Pressed then task.spawn(cfg.Pressed, isActive) end
            elseif mode == "Hold" and inp.KeyCode == bound then isActive = true; if cfg.Pressed then task.spawn(cfg.Pressed, true) end end
        end
    end)
    connect(UserInputService.InputEnded, function(inp, gp)
        if mode == "Hold" and inp.KeyCode == bound and not gp then isActive = false; if cfg.Pressed then task.spawn(cfg.Pressed, false) end end
    end)
    return NovaUI:RegisterElement({Get = function() return bound.Name end, Set = function(v, s) bound = (type(v)=="string" and Enum.KeyCode[v]) or v or Enum.KeyCode.Unknown; btn.Text = bound.Name; if cfg.Flag then NovaUI.Flags[cfg.Flag] = bound.Name end; if not s and cfg.Callback then task.spawn(cfg.Callback, bound) end end}, cfg.Name, row, cfg.Flag)
end

