                self:DeleteConfig(n)
                NovaUI:Notify({Title = "Config Deleted", Content = "Profile '"..n.."' deleted.", Duration = 2})
            end
        })
    end

    -- Info section
    local infoSection = tab:CreateSection({Name = "About"})
    infoSection:AddParagraph({Title = "NovaUI Premium", Content = "Version "..NovaUI.Version.."\nA feature-rich, themeable UI library for Roblox.\nBuilt with ❤️ using pure Lua."})

    return tab
end

return NovaUI
