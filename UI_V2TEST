function SectionMethods:AddRadioGroup(cfg)
    local options = cfg.Options or {}
    local selected = cfg.Default or (options[1] or "")
    local row = makeRow(self.Holder, 0); row.AutomaticSize = Enum.AutomaticSize.Y
    create("UIPadding", {Parent = row, PaddingTop = UDim.new(0,8), PaddingBottom = UDim.new(0,8), PaddingLeft = UDim.new(0,12), PaddingRight = UDim.new(0,12)})
