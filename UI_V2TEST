function SectionMethods:AddDropdown(cfg)
    cfg = cfg or {}

    local Dropdown = {
        Value = cfg.Default or "",
        Options = cfg.Options or {},
        Buttons = {},
        Toggled = false,
        Type = "Dropdown",
        Save = cfg.Save or false
    }

    local multi = cfg.Multi or false
    local searchable = cfg.Searchable or false
    local selected = cfg.Default or (multi and {} or "")
    local maxVisible = 5

    if multi then
        if type(selected) ~= "table" then
            selected = {}
        end
    else
        if not table.find(Dropdown.Options, selected) then
            selected = Dropdown.Options[1] or "None"
        end
    end

    local row = makeRow(self.Holder, 38)
    row.ClipsDescendants = true
    applyTooltip(row, cfg.Tooltip)

    create("TextLabel", {
        Parent = row,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.5, 0, 0, 38),
        BackgroundTransparency = 1,
        Text = cfg.Name or "Dropdown",
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local function getValText()
        if multi then
            if #selected == 0 then
                return "None"
            elseif #selected == 1 then
                return tostring(selected[1])
            else
                return tostring(#selected) .. " Selected"
            end
        else
            return tostring(selected ~= "" and selected or "None")
        end
    end

    local selectedLbl = create("TextLabel", {
        Parent = row,
        Position = UDim2.new(0.5, 0, 0, 0),
        Size = UDim2.new(0.5, -30, 0, 38),
        BackgroundTransparency = 1,
        Text = getValText(),
        Font = Enum.Font.Gotham,
        TextColor3 = NovaUI.Theme.Accent,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right,
        TextTruncate = Enum.TextTruncate.AtEnd
    })
    trackTheme("Accent", selectedLbl, "TextColor3")

    local arrow = create("TextLabel", {
        Parent = row,
        Position = UDim2.new(1, -26, 0, 0),
        Size = UDim2.new(0, 26, 0, 38),
        BackgroundTransparency = 1,
        Text = "⌄",
        Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Muted,
        TextSize = 14
    })

    local topHitbox = create("TextButton", {
        Parent = row,
        Size = UDim2.new(1, 0, 0, 38),
        BackgroundTransparency = 1,
        Text = ""
    })

    local divider = create("Frame", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 37),
        Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = NovaUI.Theme.Stroke,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Visible = false
    })

    local dropdownContainer = create("ScrollingFrame", {
        Parent = row,
        Position = UDim2.new(0, 0, 0, 38),
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 2,
        ScrollBarImageColor3 = NovaUI.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ClipsDescendants = true
    })
    trackTheme("Accent", dropdownContainer, "ScrollBarImageColor3")

    local searchBox
    if searchable then
        searchBox = create("TextBox", {
            Parent = dropdownContainer,
            Size = UDim2.new(1, -8, 0, 24),
            Position = UDim2.new(0, 4, 0, 4),
            BackgroundColor3 = NovaUI.Theme.Surface,
            Text = "",
            PlaceholderText = "Search...",
            PlaceholderColor3 = NovaUI.Theme.Muted,
            TextColor3 = NovaUI.Theme.Text,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            ClearTextOnFocus = false
        })
        applyCorner(searchBox, 6)
        applyStroke(searchBox, NovaUI.Theme.Stroke, 1, 0.5)
    end

    local listHolder = create("Frame", {
        Parent = dropdownContainer,
        Size = UDim2.new(1, 0, 0, 0),
        BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y
    })

    local listLayout = create("UIListLayout", {
        Parent = listHolder,
        SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 2)
    })

    local function updateCanvas()
        local contentHeight = listLayout.AbsoluteContentSize.Y
        if searchable and searchBox then
            contentHeight += 28
        end
        dropdownContainer.CanvasSize = UDim2.new(0, 0, 0, contentHeight)
    end

    connect(listLayout:GetPropertyChangedSignal("AbsoluteContentSize"), updateCanvas)

    local function getVisibleButtonCount()
        local visibleCount = 0
        for _, data in pairs(Dropdown.Buttons) do
            if data.Button.Visible then
                visibleCount += 1
            end
        end
        return visibleCount
    end

    local function setOpen(state)
        Dropdown.Toggled = state
        arrow.Text = state and "⌃" or "⌄"
        divider.Visible = state

        local rowsHeight = math.min(getVisibleButtonCount(), maxVisible) * 30
        local extra = searchable and 28 or 0
        local targetHeight = state and (rowsHeight + extra) or 0

        animate(row, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, 0, 0, 38 + targetHeight)
        })
        animate(dropdownContainer, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            Size = UDim2.new(1, 0, 0, targetHeight)
        })
    end

    local function syncSelectedVisual()
        selectedLbl.Text = getValText()

        for value, data in pairs(Dropdown.Buttons) do
            local button = data.Button
            local title = data.Title

            local isSelected
            if multi then
                isSelected = table.find(selected, value) ~= nil
            else
                isSelected = (selected == value)
            end

            button.BackgroundTransparency = isSelected and 0 or 1
            title.TextTransparency = isSelected and 0 or 0.35
            title.TextColor3 = isSelected and NovaUI.Theme.Accent or NovaUI.Theme.Text
        end
    end

    local function addOptionButton(option)
        local btn = create("TextButton", {
            Parent = listHolder,
            Size = UDim2.new(1, 0, 0, 28),
            BackgroundColor3 = NovaUI.Theme.Background,
            BackgroundTransparency = 1,
            BorderSizePixel = 0,
            Text = ""
        })
        applyCorner(btn, 6)

        local title = create("TextLabel", {
            Parent = btn,
            Name = "Title",
            Size = UDim2.new(1, -10, 1, 0),
            Position = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            Text = tostring(option),
            Font = Enum.Font.Gotham,
            TextColor3 = NovaUI.Theme.Text,
            TextTransparency = 0.35,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left
        })

        connect(btn.MouseButton1Click, function()
            if multi then
                local idx = table.find(selected, option)
                if idx then
                    table.remove(selected, idx)
                else
                    table.insert(selected, option)
                end
            else
                selected = option
                setOpen(false)
            end

            Dropdown.Value = selected
            syncSelectedVisual()

            if cfg.Flag then
                NovaUI.Flags[cfg.Flag] = selected
            end
            if cfg.Callback then
                task.spawn(cfg.Callback, selected)
            end
        end)

        Dropdown.Buttons[option] = {
            Button = btn,
            Title = title
        }
    end

    local function clearButtons()
        for _, data in pairs(Dropdown.Buttons) do
            if data.Button and data.Button.Parent then
                data.Button:Destroy()
            end
        end
        Dropdown.Buttons = {}
    end

    local function rebuildOptions(filterText)
        clearButtons()

        local visible = 0
        for _, option in ipairs(Dropdown.Options) do
            local text = tostring(option)
            local matches = true

            if filterText and filterText ~= "" then
                matches = string.find(string.lower(text), string.lower(filterText), 1, true) ~= nil
            end

            if matches then
                addOptionButton(option)
                visible += 1
            end
        end

        syncSelectedVisual()
        updateCanvas()

        if Dropdown.Toggled then
            local rowsHeight = math.min(visible, maxVisible) * 30
            local extra = searchable and 28 or 0
            row.Size = UDim2.new(1, 0, 0, 38 + rowsHeight + extra)
            dropdownContainer.Size = UDim2.new(1, 0, 0, rowsHeight + extra)
        end
    end

    if searchable and searchBox then
        connect(searchBox:GetPropertyChangedSignal("Text"), function()
            rebuildOptions(searchBox.Text)
        end)
    end

    connect(topHitbox.MouseButton1Click, function()
        setOpen(not Dropdown.Toggled)
    end)

    function Dropdown:Refresh(newOptions, deleteOld)
        if deleteOld == nil then
            deleteOld = true
        end

        if deleteOld then
            self.Options = {}
        end

        self.Options = newOptions or {}

        if not multi then
            if not table.find(self.Options, selected) then
                selected = self.Options[1] or "None"
            end
        else
            local fixed = {}
            for _, value in ipairs(selected) do
                if table.find(self.Options, value) then
                    table.insert(fixed, value)
                end
            end
            selected = fixed
        end

        self.Value = selected
        rebuildOptions(searchable and searchBox and searchBox.Text or nil)
        syncSelectedVisual()
    end

    function Dropdown:Set(value, skipCallback)
        if multi then
            selected = type(value) == "table" and value or {}
        else
            if table.find(Dropdown.Options, value) then
                selected = value
            else
                selected = Dropdown.Options[1] or "None"
            end
        end

        Dropdown.Value = selected
        syncSelectedVisual()

        if cfg.Flag then
            NovaUI.Flags[cfg.Flag] = selected
        end
        if not skipCallback and cfg.Callback then
            task.spawn(cfg.Callback, selected)
        end
    end

    function Dropdown:Get()
        return selected
    end

    if cfg.Flag then
        NovaUI.Flags[cfg.Flag] = selected
    end

    rebuildOptions()
    syncSelectedVisual()
    setOpen(false)

    return NovaUI:RegisterElement(Dropdown, cfg.Name or "Dropdown", row, cfg.Flag)
end


