            selected = opt; refreshRadios()
            if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected end
            if cfg.Callback then task.spawn(cfg.Callback, selected) end
        end)
    end

    refreshRadios()
    if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected end
    return NovaUI:RegisterElement({Get = function() return selected end, Set = function(v, s) selected = v; refreshRadios(); if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected end; if not s and cfg.Callback then task.spawn(cfg.Callback, selected) end end}, cfg.Name, row, cfg.Flag)
