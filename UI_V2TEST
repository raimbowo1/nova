        animate(lbl, TweenInfo.new(0.25), {TextColor3 = NovaUI.Theme.Text})
        animate(icn, TweenInfo.new(0.25), {TextColor3 = NovaUI.Theme.Text})
        animate(indicator, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,3,0,24)})
    end
    tab.Select = selectTab
    connect(tabBtn.MouseButton1Click, selectTab)
    if not self.SelectedTab then selectTab() end
    return tab
end

-- FIX: CreatePlayerTab - connections stored and cleaned on re-call
function WindowMethods:CreatePlayerTab(cfg)
    local tab = self:CreateTab({Name = cfg.Name or "Players", Icon = cfg.Icon or "👥"})
    local actions = cfg.Actions or {}
    local holder = tab.Page
    local playerConns = {}

    local function reload()
        for _, c in ipairs(holder:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
        for _, plr in ipairs(Players:GetPlayers()) do
            local row = create("Frame", {Parent = holder, Size = UDim2.new(1,0,0,46), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = NovaUI.Theme.ItemTransparency})
            applyCorner(row, 8); applyStroke(row, NovaUI.Theme.Stroke, 1, 0.4)
            create("ImageLabel", {Parent = row, Size = UDim2.new(0,34,0,34), Position = UDim2.new(0,6,0.5,0), AnchorPoint = Vector2.new(0,0.5), BackgroundColor3 = NovaUI.Theme.Background, Image = "rbxthumb://type=AvatarHeadShot&id="..plr.UserId.."&w=48&h=48"})
            create("TextLabel", {Parent = row, BackgroundTransparency = 1, Size = UDim2.new(1,-120,0,16), Position = UDim2.new(0,48,0,6), Text = plr.DisplayName, Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
            create("TextLabel", {Parent = row, BackgroundTransparency = 1, Size = UDim2.new(1,-120,0,14), Position = UDim2.new(0,48,0,24), Text = "@"..plr.Name, Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 11, TextXAlignment = Enum.TextXAlignment.Left})
            local actBtn = create("TextButton", {Parent = row, Size = UDim2.new(0,62,0,26), Position = UDim2.new(1,-12,0.5,0), AnchorPoint = Vector2.new(1,0.5), BackgroundColor3 = NovaUI.Theme.Background, BackgroundTransparency = NovaUI.Theme.ItemTransparency, Text = "Interact ⌄", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 11})
            applyCorner(actBtn, 6); applyStroke(actBtn, NovaUI.Theme.Stroke, 1, 0.5)
            local plrops = {}
            for name, cb in pairs(actions) do plrops[name] = function() cb(plr) end end
            connect(actBtn.MouseButton1Click, function() NovaUI:ShowContextMenu(plrops) end)
        end
    end

    -- FIX: disconnect old player connections before adding new
    for _, c in ipairs(playerConns) do pcall(function() c:Disconnect() end) end
    playerConns = {}
    table.insert(playerConns, Players.PlayerAdded:Connect(function() if tab.Page.Visible then reload() end end))
    table.insert(playerConns, Players.PlayerRemoving:Connect(function() task.wait(); if tab.Page.Visible then reload() end end))

    local oldSel = tab.Select
    tab.Select = function(selfArg) oldSel(); reload() end
    reload()
    return tab
end

