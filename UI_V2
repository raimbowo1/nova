function SectionMethods:AddDropdown(cfg)
    local options = cfg.Options or {}
    local multi = cfg.Multi or false
    local searchable = cfg.Searchable or false
    local selected = cfg.Default or (multi and {} or (options[1] or "..."))
    if multi and type(selected) ~= "table" then selected = {selected} end

    local row = makeRow(self.Holder, 38)
    applyTooltip(row, cfg.Tooltip)

    create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(0.5, 0, 0, 38), BackgroundTransparency = 1, Text = cfg.Name or "Dropdown", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    
    local function getValText()
        if multi then 
            if #selected == 0 then return "None"
            elseif #selected == 1 then return tostring(selected[1])
            else return tostring(#selected) .. " Selected" end
        else 
            return tostring(selected) 
        end
    end
    local valLbl = create("TextLabel", {Parent = row, Position = UDim2.new(0.5, 0, 0, 0), Size = UDim2.new(0.5, -30, 0, 38), BackgroundTransparency = 1, Text = getValText(), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Accent, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right, TextTruncate = Enum.TextTruncate.AtEnd})
    trackTheme("Accent", valLbl, "TextColor3")
    local arrow = create("TextLabel", {Parent = row, Position = UDim2.new(1, -26, 0, 0), Size = UDim2.new(0, 26, 0, 38), BackgroundTransparency = 1, Text = "⌄", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Muted, TextSize = 14})

    local ddlBase = create("Frame", { Parent = row, Position = UDim2.new(0, 0, 0, 38), Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1, ClipsDescendants = true })
    local ddlInner = create("Frame", { Parent = ddlBase, Size = UDim2.new(1, 0, 1, 0), BackgroundColor3 = NovaUI.Theme.Surface, ClipsDescendants = true }); applyCorner(ddlInner, 8); applyStroke(ddlInner, NovaUI.Theme.Stroke, 1, 0.5)
    
    local list = create("ScrollingFrame", {Parent = ddlInner, Size = UDim2.new(1, 0, 1, searchable and -30 or 0), Position = UDim2.new(0, 0, 0, searchable and 30 or 0), BackgroundTransparency = 1, ScrollBarThickness = 2, ScrollBarImageColor3 = NovaUI.Theme.Accent})
    local ll = create("UIListLayout", {Parent = list, SortOrder = Enum.SortOrder.LayoutOrder}); trackTheme("Accent", list, "ScrollBarImageColor3")

    local searchBox = nil
    if searchable then
        searchBox = create("TextBox", {Parent = ddlInner, Size = UDim2.new(1, -12, 0, 24), Position = UDim2.new(0, 6, 0, 3), BackgroundColor3 = NovaUI.Theme.Background, TextColor3 = NovaUI.Theme.Text, PlaceholderText = "Search...", PlaceholderColor3 = NovaUI.Theme.Muted, Font = Enum.Font.Gotham, TextSize = 12, Text = ""})
        applyCorner(searchBox, 4)
    end

    local open = false
    local function toggleMenu()
        open = not open; arrow.Text = open and "⌃" or "⌄"
        local maxH = math.min(#options * 30 + (searchable and 34 or 4), 180)
        list.CanvasSize = UDim2.new(0, 0, 0, #options * 30)
        animate(row, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and (38 + maxH) or 38)})
        animate(ddlBase, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and maxH or 0)})
    end
    local hitBtn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 0, 38), BackgroundTransparency = 1, Text = ""}); connect(hitBtn.MouseButton1Click, toggleMenu)

    local function buildOpts(filter)
        for _, c in ipairs(list:GetChildren()) do if c:IsA("GuiButton") then c:Destroy() end end
        local count = 0
        for _, opt in ipairs(options) do
            if not filter or string.find(tostring(opt):lower(), filter:lower()) then
                count = count + 1
                local isSel = multi and table.find(selected, opt) or (not multi and opt == selected)
                local oBtn = create("TextButton", { Parent = list, Size = UDim2.new(1, 0, 0, 30), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 1, Text = "  " .. tostring(opt), Font = Enum.Font.Gotham, TextColor3 = isSel and NovaUI.Theme.Accent or NovaUI.Theme.Text, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
                if isSel and multi then trackTheme("Accent", oBtn, "TextColor3") end
                connect(oBtn.MouseButton1Click, function()
                    if multi then
                        local idx = table.find(selected, opt)
                        if idx then 
                            table.remove(selected, idx)
                            animate(oBtn, TweenInfo.new(0.2), {TextColor3 = NovaUI.Theme.Text})
                        else 
                            table.insert(selected, opt)
                            animate(oBtn, TweenInfo.new(0.2), {TextColor3 = NovaUI.Theme.Accent})
                            trackTheme("Accent", oBtn, "TextColor3")
                        end
                        valLbl.Text = getValText()
                    else
                        selected = opt; valLbl.Text = getValText(); toggleMenu(); buildOpts()
                    end
                    if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected end
                    if cfg.Callback then task.spawn(cfg.Callback, selected) end
                end)
            end
        end
        list.CanvasSize = UDim2.new(0, 0, 0, count * 30)
    end
    buildOpts()
    if searchable then connect(searchBox.Changed, function() buildOpts(searchBox.Text) end) end

    return NovaUI:RegisterElement({Refresh = function(newOpts) options = newOpts or {}; buildOpts() end, Get = function() return selected end, Set = function(val, skipCallback) selected = val; valLbl.Text = getValText(); buildOpts(); if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected end; if not skipCallback and cfg.Callback then task.spawn(cfg.Callback, selected) end end}, cfg.Name, row, cfg.Flag)
end

