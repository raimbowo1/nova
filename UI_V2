    end

    local dragging = false
    local hitBox = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
    connect(hitBox.InputBegan, function(inp) if inp.UserInputType.Name:find("MouseButton1") then dragging = true; animate(knob, TweenInfo.new(0.2), {Size=UDim2.new(0,18,0,18)}); setVal(min + math.clamp((inp.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1) * (max - min)) end end)
