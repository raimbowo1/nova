    -- Search Bar Overlay
    local searchBtn = create("TextButton", {Parent = controls, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = self.Theme.Surface, Text = "🔍", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 12})
    applyCorner(searchBtn, 6); applyStroke(searchBtn, self.Theme.Stroke, 1, 0.5)
    
    local searchOverlay = create("TextBox", {Parent = topbar, Position = UDim2.new(0, 44, 0, 10), Size = UDim2.new(1, -160, 0, 28), BackgroundColor3 = self.Theme.Surface, BackgroundTransparency = 1, Font = Enum.Font.Gotham, TextColor3 = self.Theme.Text, PlaceholderText = "Search features...", PlaceholderColor3 = self.Theme.Muted, TextSize = 13, Text = "", Visible = false})
    applyCorner(searchOverlay, 6); local srchStr = applyStroke(searchOverlay, self.Theme.Accent, 1, 1)
    
    local searchActive = false
    connect(searchBtn.MouseButton1Click, function()
        searchActive = not searchActive
        if searchActive then
            searchOverlay.Visible = true; titleLbl.Visible = false; searchOverlay:CaptureFocus()
            animate(searchOverlay, TweenInfo.new(0.2), {BackgroundTransparency = 0})
            animate(srchStr, TweenInfo.new(0.2), {Transparency = 0})
        else
            animate(searchOverlay, TweenInfo.new(0.2), {BackgroundTransparency = 1})
            animate(srchStr, TweenInfo.new(0.2), {Transparency = 1}).Completed:Connect(function() searchOverlay.Visible = false; titleLbl.Visible = true end)
            searchOverlay.Text = "" -- clear search
        end
    end)
    connect(searchOverlay.Changed, function()
        local q = searchOverlay.Text:lower()

        local function fuzzy(s, query)
            if query == "" then return true end
            local idx = 1
            for i = 1, #query do
                local match = string.find(s, query:sub(i, i), idx, true)
                if not match then return false end
                idx = match + 1
            end
            return true
        end

        if q == "" then
            for _, e in ipairs(NovaUI.Elements) do e.Visible = true; if e.Obj.ApplyDeps then e.Obj.ApplyDeps() end end
            for _, t in ipairs(thisWindowTabs) do t.Button.Visible = true end
        else
            -- 1: Evaluate normal elements using Fuzzy matching
            for _, e in ipairs(NovaUI.Elements) do
                if not e.Obj.Holder then
                    e.Visible = fuzzy(e.Name, q)
                    if e.Obj.ApplyDeps then e.Obj.ApplyDeps() end
                end
            end

            local firstMatch = nil
            local matchTabs = {}

            -- 2: Evaluate Sections based on visible children
            for _, e in ipairs(NovaUI.Elements) do
                if e.Obj.Holder then
                    local hasVis = false
                    for _, child in ipairs(e.Obj.Holder:GetChildren()) do
                        if child:IsA("GuiObject") and child.Visible then hasVis = true; break end
                    end
                    
                    e.Visible = hasVis or fuzzy(e.Name, q)
                    if e.Obj.ApplyDeps then e.Obj.ApplyDeps() end
                    
                    if e.Visible and e.Row and e.Row.Parent and e.Row.Parent:IsA("ScrollingFrame") then
                        for _, t in ipairs(thisWindowTabs) do
                            if t.Page == e.Row.Parent then
                                matchTabs[t] = true
                                if not firstMatch then firstMatch = t end
                                break
                            end
                        end
                    end
                end
            end

            -- 3: Update tabs and strictly select first matching
            for _, t in ipairs(thisWindowTabs) do
                t.Button.Visible = matchTabs[t] == true
            end
            if firstMatch and firstMatch.Select then firstMatch:Select() end
        end
    end)

    local minBtn = create("TextButton", {Parent = controls, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = self.Theme.Surface, Text = "−", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 14})
    applyCorner(minBtn, 6); applyStroke(minBtn, self.Theme.Stroke, 1, 0.5)
    local closeBtn = create("TextButton", {Parent = controls, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = self.Theme.Surface, Text = "×", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Danger, TextSize = 14})
    applyCorner(closeBtn, 6); applyStroke(closeBtn, self.Theme.Stroke, 1, 0.5)

    local sep = create("Frame", {Parent = root, Position = UDim2.new(0, sidebarWidth + 12, 0, 48), Size = UDim2.new(0, 1, 1, -48), BackgroundColor3 = self.Theme.Stroke, BackgroundTransparency = 0.4, BorderSizePixel = 0})
    local sidebar = create("ScrollingFrame", { Parent = root, BackgroundTransparency = 1, Position = UDim2.new(0, 6, 0, 48), Size = UDim2.new(0, sidebarWidth, 1, -60), ScrollBarThickness = 0, AutomaticCanvasSize = Enum.AutomaticSize.Y })
    create("UIListLayout", {Parent = sidebar, Padding = UDim.new(0, 6), SortOrder = Enum.SortOrder.LayoutOrder})

    local contentHolder = create("Frame", { Parent = root, BackgroundTransparency = 1, Position = UDim2.new(0, sidebarWidth + 24, 0, 48), Size = UDim2.new(1, -(sidebarWidth + 36), 1, -60), ClipsDescendants = true })

    -- Sidebar Collapse Logic
    local sidebarOpen = true
    connect(menuBtn.MouseButton1Click, function()
        sidebarOpen = not sidebarOpen
        local nw = sidebarOpen and sidebarWidth or 42
        animate(menuBtn, TweenInfo.new(0.3), {Rotation = sidebarOpen and 0 or 90})
        animate(sidebar, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, nw, 1, -60)})
        animate(sep, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0, nw + 12, 0, 48)})
        animate(contentHolder, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {
            Position = UDim2.new(0, nw + 24, 0, 48),
            Size = UDim2.new(1, -(nw + 36), 1, -60)
        })
        -- Hide/show tab text
        for _, tab in ipairs(thisWindowTabs) do
            if tab.LabelText then
                animate(tab.LabelText, TweenInfo.new(0.3), {TextTransparency = sidebarOpen and 0 or 1})
            end
        end
    end)

    local minimized = false
    connect(minBtn.MouseButton1Click, function()
        minimized = not minimized
        animate(shadow, TweenInfo.new(0.4, Enum.EasingStyle.Exponential), {Size = minimized and UDim2.new(0, clampedX, 0, 48) + UDim2.new(0, 40, 0, 40) or defaultSize + UDim2.new(0, 40, 0, 40)})
        contentHolder.Visible = not minimized; sidebar.Visible = not minimized; sep.Visible = not minimized
    end)

    connect(closeBtn.MouseButton1Click, function() NovaUI:Toggle(false) end)

    if cfg.UseToggleButton ~= false then
        local btn = create("TextButton", { Parent = gui, Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0, 20, 0.5, 0), AnchorPoint = Vector2.new(0, 0.5), BackgroundColor3 = self.Theme.Surface, Text = cfg.ToggleButtonText or "UI", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 13, BackgroundTransparency = 1, TextTransparency = 1, Visible = false })
