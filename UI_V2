    local section = create("Frame", {
        Parent = self.Page, Size = UDim2.new(1, 0, 0, 0),
        BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0,
        AutomaticSize = Enum.AutomaticSize.Y
    })
    applyCorner(section, 10)
    applyStroke(section, NovaUI.Theme.Stroke, 1, 0.5)

    -- Collapsible header
    local header = create("TextButton", {
        Parent = section, Size = UDim2.new(1, 0, 0, 36),
        BackgroundTransparency = 1, Text = "", AutoButtonColor = false
    })
    create("TextLabel", {
        Parent = header, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -36, 1, 0),
        BackgroundTransparency = 1, Text = cfg.Name or "Section",
        Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text,
        TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left
    })
    local arrowLbl = create("TextLabel", {
        Parent = header, Position = UDim2.new(1, -28, 0, 0), Size = UDim2.new(0, 24, 1, 0),
        BackgroundTransparency = 1, Text = "⌄", Font = Enum.Font.GothamBold,
        TextColor3 = NovaUI.Theme.Muted, TextSize = 14
    })

    create("Frame", {
        Parent = section, Position = UDim2.new(0, 12, 0, 36),
        Size = UDim2.new(1, -24, 0, 1), BackgroundColor3 = NovaUI.Theme.Stroke, BackgroundTransparency = 0.5, BorderSizePixel = 0
    })

    local holder = create("Frame", {
        Parent = section, Position = UDim2.new(0, 12, 0, 44),
        Size = UDim2.new(1, -24, 0, 0), BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y
    })
    create("UIListLayout", {Parent = holder, Padding = UDim.new(0, 8), SortOrder = Enum.SortOrder.LayoutOrder})
    create("UIPadding", {Parent = holder, PaddingBottom = UDim.new(0, 12)})

    local isCollapsed = cfg.Collapsed or false
    local function setCollapsed(v)
        isCollapsed = v
        holder.Visible = not isCollapsed
        arrowLbl.Text = isCollapsed and "›" or "⌄"
        animate(arrowLbl, TweenInfo.new(0.2), {TextColor3 = isCollapsed and NovaUI.Theme.Accent or NovaUI.Theme.Muted})
    end
    connect(header.MouseButton1Click, function() setCollapsed(not isCollapsed) end)
    setCollapsed(isCollapsed)

    local secObj = {Holder = holder}
    setmetatable(secObj, {__index = SectionMethods})
    return secObj
end

local function makeRow(parent, h)
    local r = create("Frame", {Parent = parent, Size = UDim2.new(1, 0, 0, h), BackgroundColor3 = NovaUI.Theme.Background, BackgroundTransparency = 0})
    applyCorner(r, 8)
    applyStroke(r, NovaUI.Theme.Stroke, 1, 0.6)
    return r
end

function SectionMethods:AddSeparator()
    create("Frame", {
        Parent = self.Holder, Size = UDim2.new(1, 0, 0, 1),
        BackgroundColor3 = NovaUI.Theme.Stroke, BackgroundTransparency = 0.4, BorderSizePixel = 0
    })
end

function SectionMethods:AddLabel(text)
    local lbl = create("TextLabel", {
        Parent = self.Holder, Size = UDim2.new(1, 0, 0, 26),
        BackgroundTransparency = 1, Text = text or "",
        Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted,
        TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left
    })
    return {Set = function(t) lbl.Text = t end}
end

function SectionMethods:AddButton(cfg)
    local row = makeRow(self.Holder, 38)
    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Button", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13})

    connect(btn.MouseEnter, function() animate(row, TweenInfo.new(0.18), {BackgroundColor3 = NovaUI.Theme.SurfaceHover}) end)
    connect(btn.MouseLeave, function() animate(row, TweenInfo.new(0.18), {BackgroundColor3 = NovaUI.Theme.Background}) end)
    connect(btn.MouseButton1Down, function()
        animate(row, TweenInfo.new(0.1), {Size = UDim2.new(1, -4, 0, 36), Position = UDim2.new(0, 2, 0, 1)})
    end)
    connect(btn.MouseButton1Up, function()
        animate(row, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(1, 0, 0, 38), Position = UDim2.new(0, 0, 0, 0)})
    end)

    -- Ripple
    connect(btn.MouseButton1Click, function()
        local mp = UserInputService:GetMouseLocation()
        local rel = mp - Vector2.new(row.AbsolutePosition.X, row.AbsolutePosition.Y)
        local rpl = create("Frame", {
            Parent = row, AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0, rel.X, 0, rel.Y), Size = UDim2.new(0, 0, 0, 0),
            BackgroundColor3 = NovaUI.Theme.Text, BackgroundTransparency = 0.8, BorderSizePixel = 0, ZIndex = row.ZIndex + 2
        })
        applyCorner(rpl, 999)
        local tw = animate(rpl, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {
            Size = UDim2.new(0, row.AbsoluteSize.X * 2, 0, row.AbsoluteSize.X * 2),
            BackgroundTransparency = 1
        })
        tw.Completed:Connect(function() rpl:Destroy() end)
        if cfg.Callback then task.spawn(cfg.Callback) end
    end)
end

function SectionMethods:AddToggle(cfg)
    local row = makeRow(self.Holder, 42)
    create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -70, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Toggle", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})

    local box = create("Frame", {Parent = row, Position = UDim2.new(1, -54, 0.5, -12), Size = UDim2.new(0, 42, 0, 24), BackgroundColor3 = NovaUI.Theme.Background})
    applyCorner(box, 12); applyStroke(box, NovaUI.Theme.Stroke, 1)

    local knob = create("Frame", {Parent = box, Position = UDim2.new(0, 2, 0.5, -10), Size = UDim2.new(0, 20, 0, 20), BackgroundColor3 = NovaUI.Theme.Text})
    applyCorner(knob, 10)

    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})

    local state = cfg.Default or false
    local function setToggle(v, skipCallback)
        state = v
        -- Squish knob on toggle
        animate(knob, TweenInfo.new(0.1), {Size = UDim2.new(0, 26, 0, 18)})
        task.delay(0.1, function()
            animate(box, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.Background})
            animate(knob, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Position = state and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10),
                Size = UDim2.new(0, 20, 0, 20)
            })
        end)
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = state end
        if not skipCallback and cfg.Callback then task.spawn(cfg.Callback, state) end
    end

    connect(btn.MouseButton1Click, function() setToggle(not state) end)
    setToggle(state, true)
    table.insert(NovaUI.ThemeObjects.ToggleBoxes, {box, function() return state end})
    return {Set = setToggle, Get = function() return state end}
end

function SectionMethods:AddSlider(cfg)
    local min, max, inc = cfg.Min or 0, cfg.Max or 100, cfg.Increment or 1
    local row = makeRow(self.Holder, 54)

    create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 8), Size = UDim2.new(1, -24, 0, 16), BackgroundTransparency = 1, Text = cfg.Name or "Slider", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local valLbl = create("TextLabel", {Parent = row, Position = UDim2.new(1, -62, 0, 8), Size = UDim2.new(0, 50, 0, 16), BackgroundTransparency = 1, Text = tostring(cfg.Default or min), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right})

    local bar = create("Frame", {Parent = row, Position = UDim2.new(0, 12, 0, 34), Size = UDim2.new(1, -24, 0, 6), BackgroundColor3 = NovaUI.Theme.Surface})
    applyCorner(bar, 3)
    local fill = create("Frame", {Parent = bar, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = NovaUI.Theme.Accent})
    applyCorner(fill, 3)
    trackTheme("Accent", fill, "BackgroundColor3")
    local knob = create("Frame", {Parent = fill, AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.new(0, 14, 0, 14), BackgroundColor3 = NovaUI.Theme.Text})
    applyCorner(knob, 7)

    local function setVal(v, skip)
        v = math.clamp(math.floor(v / inc + 0.5) * inc, min, max)
        local pct = (max == min) and 0 or (v - min) / (max - min)
        animate(fill, TweenInfo.new(0.1), {Size = UDim2.new(pct, 0, 1, 0)})
        valLbl.Text = tostring(v) .. (cfg.ValueName or cfg.Suffix or "")
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = v end
        if not skip and cfg.Callback then task.spawn(cfg.Callback, v) end
    end

    local dragging = false
    local function update(input)
        local pct = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        setVal(min + pct * (max - min))
    end

    local hitBox = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
    connect(hitBox.InputBegan, function(inp)
        if inp.UserInputType.Name:find("MouseButton1") or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0, 18, 0, 18)})
            update(inp)
        end
    end)
    connect(hitBox.InputEnded, function(inp)
        if inp.UserInputType.Name:find("MouseButton1") or inp.UserInputType == Enum.UserInputType.Touch then
            dragging = false
            animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0, 14, 0, 14)})
        end
    end)
    connect(UserInputService.InputChanged, function(inp)
        if dragging and (inp.UserInputType.Name:find("MouseMovement") or inp.UserInputType == Enum.UserInputType.Touch) then update(inp) end
    end)

    setVal(cfg.Default or min, true)
    return {Set = setVal, Get = function()
        local pct = fill.Size.X.Scale
        return math.clamp(math.floor((min + pct * (max - min)) / inc + 0.5) * inc, min, max)
    end}
end

