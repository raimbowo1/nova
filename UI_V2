    local box = create("TextBox", {
        Parent = row, Position = UDim2.new(1, -162, 0.5, -14), Size = UDim2.new(0, 150, 0, 28),
        BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0,
        Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Text,
        PlaceholderColor3 = NovaUI.Theme.Muted, PlaceholderText = cfg.Placeholder or "Type...",
        Text = cfg.Default or "", TextSize = 12
    })
    applyCorner(box, 6); applyStroke(box, NovaUI.Theme.Stroke, 1, 0.5)

    connect(box.Focused, function() animate(box.UIStroke, TweenInfo.new(0.2), {Transparency = 0, Color = NovaUI.Theme.Accent}) end)
    connect(box.FocusLost, function(enter)
        animate(box.UIStroke, TweenInfo.new(0.2), {Transparency = 0.5, Color = NovaUI.Theme.Stroke})
