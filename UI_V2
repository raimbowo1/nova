    local disp = create("Frame", {Parent = row, Position = UDim2.new(1, -44, 0.5, -12), Size = UDim2.new(0, 32, 0, 24), BackgroundColor3 = selected})
    applyCorner(disp, 6); applyStroke(disp, NovaUI.Theme.Stroke, 1, 0.5)

    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
    connect(btn.MouseButton1Click, function()
        -- Mini cycle for now to keep it lightweight!
        local h, s, v = selected:ToHSV()
        h = (h + 0.1) % 1.0
        selected = Color3.fromHSV(h, s > 0 and s or 0.8, 1)
        animate(disp, TweenInfo.new(0.2), {BackgroundColor3 = selected})
        if cfg.ApplyAccent then NovaUI:SetTheme({Accent = selected}) end
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected:ToHex() end
        if cfg.Callback then task.spawn(cfg.Callback, selected) end
    end)
    if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected:ToHex() end

    return NovaUI:RegisterElement({Set = function(c, skipCallback) if type(c) == "string" then pcall(function() c = Color3.fromHex(c) end) end; if typeof(c) ~= "Color3" then c = Color3.new(1,1,1) end; selected = c; animate(disp, TweenInfo.new(0.2), {BackgroundColor3 = selected}); if cfg.ApplyAccent then NovaUI:SetTheme({Accent = selected}) end; if cfg.Flag then NovaUI.Flags[cfg.Flag] = selected:ToHex() end; if not skipCallback and cfg.Callback then task.spawn(cfg.Callback, selected) end end, Get = function() return selected end}, cfg.Name, row, cfg.Flag)
end

function SectionMethods:AddParagraph(cfg)
    local row = makeRow(self.Holder, 0); row.AutomaticSize = Enum.AutomaticSize.Y
    create("UIPadding", {Parent = row, PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})
    create("UIListLayout", {Parent = row, Padding = UDim.new(0, 4)})
    local t = create("TextLabel", {Parent = row, Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1, Text = cfg.Title or "Paragraph", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local b = create("TextLabel", {Parent = row, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Text = cfg.Content or "", Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 12, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top})
    return NovaUI:RegisterElement({Set = function(ti, co) if ti then t.Text = ti end; if co then b.Text = co end end}, cfg.Title, row)
end

function NovaUI:Notify(cfg)
    local gui = self:_ensureGui()
    local holder = gui:FindFirstChild("NotifyHolder")
    if not holder then
        holder = create("Frame", {Parent = gui, Name = "NotifyHolder", BackgroundTransparency = 1, Size = UDim2.new(0, 300, 1, -40), Position = UDim2.new(1, -20, 0, 20), AnchorPoint = Vector2.new(1, 0)})
    end

    local msg = create("Frame", {Parent = holder, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = self.Theme.Surface, Position = UDim2.new(1, 50, 1, 0)})
    applyCorner(msg, 10); applyStroke(msg, self.Theme.Stroke, 1, 0.3)
    create("UIPadding", {Parent = msg, PaddingLeft = UDim.new(0, 18), PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})
    local accent = create("Frame", {Parent = msg, Position = UDim2.new(0, -18, 0, 0), Size = UDim2.new(0, 3, 0, 0), BackgroundColor3 = self.Theme.Accent}); applyCorner(accent, 4)

    local contentHolder = create("Frame", {Parent = msg, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y})
    create("UIListLayout", {Parent = contentHolder, Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder})

    create("TextLabel", {Parent = contentHolder, LayoutOrder = 1, Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1, Text = cfg.Title or "Notification", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left})
    create("TextLabel", {Parent = contentHolder, LayoutOrder = 2, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Text = cfg.Content or "", Font = Enum.Font.Gotham, TextColor3 = self.Theme.Muted, TextSize = 13, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left})

    local closed = false
    local closeNotif

    if cfg.Buttons then
        local btnLayout = create("Frame", {Parent = contentHolder, LayoutOrder = 3, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 32)})
        create("UIListLayout", {Parent = btnLayout, FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 8), HorizontalAlignment = Enum.HorizontalAlignment.Right, VerticalAlignment = Enum.VerticalAlignment.Bottom})
        for _, btnData in ipairs(cfg.Buttons) do
            local nb = create("TextButton", {Parent = btnLayout, AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.new(0, 0, 0, 24), BackgroundColor3 = self.Theme.Background, Text = btnData.Name or "Btn", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 12})
            create("UIPadding", {Parent = nb, PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})
            applyCorner(nb, 6); applyStroke(nb, self.Theme.Stroke, 1, 0.4)
            connect(nb.MouseButton1Click, function()
                if btnData.Callback then task.spawn(btnData.Callback) end
                if closeNotif then closeNotif() end
            end)
        end
    end

    table.insert(self.Notifications, msg)
    
    local function updateQueue()
        local yOffset = 0
        for i = #self.Notifications, 1, -1 do
            local n = self.Notifications[i]
            local h = n.AbsoluteSize.Y > 0 and n.AbsoluteSize.Y or 60
            yOffset = yOffset + h + 8
            animate(n, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Position = UDim2.new(0, 0, 1, -yOffset)})
        end
    end

    closeNotif = function()
        if closed then return end; closed = true
        animate(msg, TweenInfo.new(0.3, Enum.EasingStyle.Sine), {Position = UDim2.new(1, 50, msg.Position.Y.Scale, msg.Position.Y.Offset), BackgroundTransparency = 1})
        for _, v in ipairs(msg:GetDescendants()) do if v:IsA("TextLabel") or v:IsA("TextButton") then animate(v, TweenInfo.new(0.3), {TextTransparency = 1, BackgroundTransparency = 1}) end end
        if msg:FindFirstChild("UIStroke") then animate(msg.UIStroke, TweenInfo.new(0.3), {Transparency = 1}) end
        task.wait(0.3)
        local idx = table.find(self.Notifications, msg)
        if idx then table.remove(self.Notifications, idx) end
        msg:Destroy()
        updateQueue()
    end

    updateQueue(); task.delay(0.05, updateQueue)
    task.delay(0.1, function() animate(accent, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 3, 1, 0)}) end)

    if not cfg.Buttons then
        task.delay(cfg.Duration or 3, closeNotif)
    end
end

function NovaUI:ShowContextMenu(options)
    if self.ActiveContextMenu then self.ActiveContextMenu:Destroy() end
    local uis = game:GetService("UserInputService")
    local mouseLoc = uis:GetMouseLocation()
    local ctx = create("Frame", {Parent = self:_ensureGui(), Size = UDim2.new(0, 140, 0, 0), Position = UDim2.new(0, mouseLoc.X, 0, mouseLoc.Y - 36), AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = self.Theme.Surface, ZIndex = 50})
    applyCorner(ctx, 8); applyStroke(ctx, self.Theme.Stroke, 1, 0.3)
    create("UIListLayout", {Parent = ctx, Padding = UDim.new(0, 2)})
    create("UIPadding", {Parent = ctx, PaddingTop = UDim.new(0, 6), PaddingBottom = UDim.new(0, 6), PaddingLeft = UDim.new(0, 6), PaddingRight = UDim.new(0, 6)})
    
    for name, callback in pairs(options) do
        local btn = create("TextButton", {Parent = ctx, Size = UDim2.new(1, 0, 0, 24), BackgroundTransparency = 1, Text = "  " .. name, Font = Enum.Font.Gotham, TextColor3 = self.Theme.Text, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left, ZIndex = 51})
        applyCorner(btn, 4)
        connect(btn.MouseButton1Click, function() ctx:Destroy(); task.spawn(callback) end)
        connect(btn.MouseEnter, function() animate(btn, TweenInfo.new(0.2), {BackgroundColor3 = self.Theme.Background, BackgroundTransparency = 0, TextColor3 = self.Theme.Accent}) end)
        connect(btn.MouseLeave, function() animate(btn, TweenInfo.new(0.2), {BackgroundTransparency = 1, TextColor3 = self.Theme.Text}) end)
    end
    self.ActiveContextMenu = ctx
    task.delay(0.1, function()
        local c; c = uis.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 or input.UserInputType == Enum.UserInputType.Touch then
                if ctx and ctx.Parent then ctx:Destroy() end
                c:Disconnect()
            end
        end)
    end)
end

function WindowMethods:SaveConfig()
    if not NovaUI.SaveConfig or not NovaUI.ConfigFolder then return false, "No ConfigFolder set" end
    if not isfolder(NovaUI.ConfigFolder) then makefolder(NovaUI.ConfigFolder) end
    local path = NovaUI.ConfigFolder .. "/" .. (self.ConfigName or "default") .. ".json"
    local data = game:GetService("HttpService"):JSONEncode(NovaUI.Flags)
    writefile(path, data)
    return true
end

function WindowMethods:LoadConfig(cfgName)
    if not NovaUI.ConfigFolder then return false, "No ConfigFolder set" end
    local path = NovaUI.ConfigFolder .. "/" .. (cfgName or self.ConfigName or "default") .. ".json"
    if not isfile(path) then return false, "Config not found" end
    local ok, data = pcall(function() return game:GetService("HttpService"):JSONDecode(readfile(path)) end)
    if not ok or type(data) ~= "table" then return false, "Corrupt config" end
    
    for k, v in pairs(data) do
        NovaUI.Flags[k] = v
        for _, elem in ipairs(NovaUI.Elements) do
            if elem.Flag == k and elem.Obj.Set then
                elem.Obj.Set(v, true)
            end
        end
    end
    NovaUI:CheckDependencies()
    return true
end

return NovaUI
