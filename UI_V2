function SectionMethods:AddDropdown(cfg)
    local options = cfg.Options or {}
    local selected = cfg.Default or options[1] or "..."
    local row = makeRow(self.Holder, 38)

    -- Fixed-height header labels so they don't stretch over the open list
    create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(0.5, 0, 0, 38), BackgroundTransparency = 1, Text = cfg.Name or "Dropdown", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local valLbl = create("TextLabel", {Parent = row, Position = UDim2.new(0.5, 0, 0, 0), Size = UDim2.new(0.5, -30, 0, 38), BackgroundTransparency = 1, Text = tostring(selected), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Accent, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right})
    trackTheme("Accent", valLbl, "TextColor3")
    local arrow = create("TextLabel", {Parent = row, Position = UDim2.new(1, -26, 0, 0), Size = UDim2.new(0, 26, 0, 38), BackgroundTransparency = 1, Text = "⌄", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Muted, TextSize = 14})

    -- Container clips all option items to rounded corners — no overlapping individual borders
    local ddlBase = create("Frame", {
        Parent = row, Position = UDim2.new(0, 0, 0, 38),
        Size = UDim2.new(1, 0, 0, 0), BackgroundTransparency = 1, ClipsDescendants = true
    })

    local ddlInner = create("Frame", {
        Parent = ddlBase, Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0,
        ClipsDescendants = true
    })
    applyCorner(ddlInner, 8)
    applyStroke(ddlInner, NovaUI.Theme.Stroke, 1, 0.5)
    create("UIListLayout", {Parent = ddlInner, Padding = UDim.new(0, 0), SortOrder = Enum.SortOrder.LayoutOrder})

    local open = false
    local function toggleMenu()
        open = not open
        arrow.Text = open and "⌃" or "⌄"
        local totalH = #options * 30 + 4
        animate(row, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and (38 + totalH) or 38)})
        animate(ddlBase, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and totalH or 0)})
    end

    local hitBtn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 0, 38), BackgroundTransparency = 1, Text = ""})
    connect(hitBtn.MouseButton1Click, toggleMenu)

    local function buildOpts()
        for _, c in ipairs(ddlInner:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for i, opt in ipairs(options) do
            local oBtn = create("TextButton", {
                Parent = ddlInner, Size = UDim2.new(1, 0, 0, 30),
                BackgroundColor3 = (tostring(opt) == tostring(selected)) and NovaUI.Theme.SurfaceHover or NovaUI.Theme.Surface,
                BackgroundTransparency = 0,
                Text = tostring(opt), Font = Enum.Font.Gotham,
                TextColor3 = NovaUI.Theme.Text, TextSize = 12
            })
            connect(oBtn.MouseEnter, function() animate(oBtn, TweenInfo.new(0.15), {BackgroundColor3 = NovaUI.Theme.SurfaceHover}) end)
            connect(oBtn.MouseLeave, function()
                animate(oBtn, TweenInfo.new(0.15), {BackgroundColor3 = (tostring(opt) == tostring(selected)) and NovaUI.Theme.SurfaceHover or NovaUI.Theme.Surface})
            end)
            connect(oBtn.MouseButton1Click, function()
                selected = opt
                valLbl.Text = tostring(opt)
                toggleMenu()
                if cfg.Flag then NovaUI.Flags[cfg.Flag] = opt end
                if cfg.Callback then task.spawn(cfg.Callback, opt) end
                buildOpts()
            end)
        end
    end
    buildOpts()
    return {
        Refresh = function(newOpts) options = newOpts or {}; buildOpts() end,
        Get = function() return selected end
    }
end

function SectionMethods:AddTextbox(cfg)
    local row = makeRow(self.Holder, 42)
