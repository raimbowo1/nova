            animate(sBtn, TweenInfo.new(0.1, Enum.EasingStyle.Bounce), {Size = UDim2.new(0, 20, 0, 20)})
            task.wait(0.1)
            animate(sBtn, TweenInfo.new(0.2), {Size = UDim2.new(0, 24, 0, 24)})
