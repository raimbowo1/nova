function SectionMethods:AddBind(cfg)
    local bound = cfg.Default or Enum.KeyCode.Unknown
    local row = makeRow(self.Holder, 42)
    create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(0.5, 0, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Keybind", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})

    local btn = create("TextButton", {
        Parent = row, Position = UDim2.new(1, -112, 0.5, -14), Size = UDim2.new(0, 100, 0, 28),
        BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0,
        Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Accent, Text = bound.Name, TextSize = 12
    })
    applyCorner(btn, 6); applyStroke(btn, NovaUI.Theme.Stroke, 1, 0.5)
    trackTheme("Accent", btn, "TextColor3")

    local listening = false
    connect(btn.MouseButton1Click, function()
        listening = true; btn.Text = "..."
        animate(btn.UIStroke, TweenInfo.new(0.2), {Color = NovaUI.Theme.Accent, Transparency = 0})
    end)
    connect(UserInputService.InputBegan, function(inp, gp)
        if listening and inp.KeyCode ~= Enum.KeyCode.Unknown then
            listening = false; bound = inp.KeyCode; btn.Text = bound.Name
            animate(btn.UIStroke, TweenInfo.new(0.2), {Color = NovaUI.Theme.Stroke, Transparency = 0.5})
            if cfg.Flag then NovaUI.Flags[cfg.Flag] = bound.Name end
            if cfg.Callback then task.spawn(cfg.Callback, bound) end
        elseif not listening and inp.KeyCode == bound and not gp then
            if cfg.Pressed then task.spawn(cfg.Pressed) end
        end
    end)
end

