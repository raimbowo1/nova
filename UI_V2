    connect(UserInputService.InputChanged, function(inp) if dragging and inp.UserInputType.Name:find("MouseMovement") then setVal(min + math.clamp((inp.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1) * (max - min)) end end)

    setVal(cfg.Default or min, true)
    return NovaUI:RegisterElement({Set = setVal, Get = function() return math.clamp(math.floor((min + fill.Size.X.Scale * (max - min)) / inc + 0.5) * inc, min, max) end}, cfg.Name, row, cfg.Flag)
