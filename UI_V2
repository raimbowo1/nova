local function connect(signal, fn)
    local c = signal:Connect(fn)
    table.insert(NovaUI.Connections, c)
    return c
end

local function disconnectAll()
    for _, c in ipairs(NovaUI.Connections) do
        pcall(function() c:Disconnect() end)
    end
    table.clear(NovaUI.Connections)
end

local function create(className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do obj[k] = v end
    return obj
end

local function applyCorner(parent, radius)
    return create("UICorner", {CornerRadius = UDim.new(0, radius or 8), Parent = parent})
end

local function applyStroke(parent, color, thickness, alpha)
    return create("UIStroke", {
        Color = color or NovaUI.Theme.Stroke,
        Thickness = thickness or 1,
        Transparency = alpha or 0,
        Parent = parent
    })
end

local function safeParentGui(gui)
    local ok, res = pcall(function()
        if gethui then return gethui() end
        if syn and syn.protect_gui then syn.protect_gui(gui); return CoreGui end
        if cloneref then return cloneref(CoreGui) end
        return CoreGui
    end)
    if ok and res then return res end
    local pg = LocalPlayer and (LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5))
    return pg or CoreGui
end

local function makeDraggable(handle, target)
    local dragging, dragInput, startPos, startFramePos = false, nil, nil, nil
    connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = input.Position
            startFramePos = target.Position
            connect(input.Changed, function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    connect(handle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    connect(UserInputService.InputChanged, function(input)
        if dragging and input == dragInput then
            local delta = input.Position - startPos
            target.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
        end
    end)
end

local function animate(obj, info, props)
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

function NovaUI:_ensureGui()
    if self.ScreenGui and self.ScreenGui.Parent then return self.ScreenGui end
    local gui = create("ScreenGui", {Name = "NovaUI", ResetOnSpawn = false, IgnoreGuiInset = true, ZIndexBehavior = Enum.ZIndexBehavior.Global})
    for _, child in ipairs(safeParentGui(gui):GetChildren()) do
        if child.Name == gui.Name then pcall(function() child:Destroy() end) end
    end
    gui.Parent = safeParentGui(gui)
    self.ScreenGui = gui
    return gui
end

function NovaUI:Toggle(force)
    if not self.MainScale then return end
    if force == nil then
        self.Hidden = not self.Hidden
    else
        self.Hidden = not force
    end
    
    animate(self.MainScale, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {
        Scale = self.Hidden and 0 or 1
    })
    
    if self.ToggleButton then
        animate(self.ToggleButton, TweenInfo.new(0.3), {BackgroundTransparency = self.Hidden and 0.5 or 0})
    end
end

function NovaUI:SetTheme(patch)
    if type(patch) ~= "table" then return end
    for k, v in pairs(patch) do
        if self.Theme[k] ~= nil then self.Theme[k] = v end
    end
    -- In a full implementation, this tracks elements and updates them dynamically
end

