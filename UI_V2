local function connect(signal, fn)
    local c = signal:Connect(fn)
    table.insert(NovaUI.Connections, c)
    return c
end

local function disconnectAll()
    for _, c in ipairs(NovaUI.Connections) do pcall(function() c:Disconnect() end) end
    table.clear(NovaUI.Connections)
end

local function create(className, props)
    local obj = Instance.new(className)
    for k, v in pairs(props or {}) do obj[k] = v end
    return obj
end

local function applyCorner(parent, radius)
    return create("UICorner", {CornerRadius = UDim.new(0, radius or 8), Parent = parent})
end

local function applyStroke(parent, color, thickness, alpha)
    return create("UIStroke", {Color = color or NovaUI.Theme.Stroke, Thickness = thickness or 1, Transparency = alpha or 0, Parent = parent})
end

local function safeParentGui(gui)
    local ok, res = pcall(function()
        if gethui then return gethui() end
        if syn and syn.protect_gui then syn.protect_gui(gui); return CoreGui end
        if cloneref then return cloneref(CoreGui) end
        return CoreGui
    end)
    if ok and res then return res end
    local pg = LocalPlayer and (LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui", 5))
    return pg or CoreGui
end

local function makeDraggable(handle, target)
    local dragging, dragInput, startPos, startFramePos = false, nil, nil, nil
    connect(handle.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            startPos = input.Position
            startFramePos = target.Position
            connect(input.Changed, function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    connect(handle.InputChanged, function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    connect(UserInputService.InputChanged, function(input)
        if dragging and input == dragInput then
            local delta = input.Position - startPos
            target.Position = UDim2.new(startFramePos.X.Scale, startFramePos.X.Offset + delta.X, startFramePos.Y.Scale, startFramePos.Y.Offset + delta.Y)
        end
    end)
end

local function animate(obj, info, props)
    local tw = TweenService:Create(obj, info, props)
    tw:Play()
    return tw
end

local function trackTheme(key, obj, prop)
    if NovaUI.ThemeObjects[key] then
        table.insert(NovaUI.ThemeObjects[key], {obj, prop})
    end
end

function NovaUI:_ensureGui()
    if self.ScreenGui and self.ScreenGui.Parent then return self.ScreenGui end
    local gui = create("ScreenGui", {Name = "NovaUI", ResetOnSpawn = false, IgnoreGuiInset = true, ZIndexBehavior = Enum.ZIndexBehavior.Global})
    for _, child in ipairs(safeParentGui(gui):GetChildren()) do
        if child.Name == gui.Name then pcall(function() child:Destroy() end) end
    end
    gui.Parent = safeParentGui(gui)
    self.ScreenGui = gui
    return gui
end

function NovaUI:Toggle(force)
    if not self.MainScale then return end
    if force == nil then
        self.Hidden = not self.Hidden
    else
        self.Hidden = not force
    end
    animate(self.MainScale, TweenInfo.new(0.4, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {Scale = self.Hidden and 0 or 1})
    if self.ToggleButton then
        animate(self.ToggleButton, TweenInfo.new(0.3), {BackgroundTransparency = self.Hidden and 0.5 or 0})
    end
end

function NovaUI:SetTheme(patch)
    if type(patch) ~= "table" then return end
    for k, v in pairs(patch) do
        if self.Theme[k] ~= nil then
            self.Theme[k] = v
            if self.ThemeObjects[k] then
                for _, entry in ipairs(self.ThemeObjects[k]) do
                    local obj, prop = entry[1], entry[2]
                    if obj and obj.Parent then
                        pcall(function()
                            if prop == "ScrollBarImageColor3" or prop == "ImageColor3" then
                                obj[prop] = v
                            else
                                animate(obj, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {[prop] = v})
                            end
                        end)
                    end
                end
            end
            if k == "Accent" then
                for _, entry in ipairs(self.ThemeObjects.ToggleBoxes) do
                    local box, getState = entry[1], entry[2]
                    if box and box.Parent and getState() then
                        animate(box, TweenInfo.new(0.4, Enum.EasingStyle.Quint), {BackgroundColor3 = v})
                    end
                end
            end
        end
    end
end

function NovaUI:SetAccent(color)
    self:SetTheme({Accent = color})
end

function NovaUI:Init()
    if self.MainScale then
        self.Hidden = false
        animate(self.MainScale, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1})
        if self.MainFrame then
            animate(self.MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Quint), {ImageTransparency = 0.5})
        end
    end
end

local WindowMethods, TabMethods, SectionMethods = {}, {}, {}

function NovaUI:CreateWindow(cfg)
    cfg = cfg or {}
    local gui = self:_ensureGui()
    self.SaveConfig = cfg.SaveConfig or false

    local defaultSizeX = cfg.Size and cfg.Size.X.Offset or 550
    local defaultSizeY = cfg.Size and cfg.Size.Y.Offset or 380
    local vp = workspace.CurrentCamera.ViewportSize
    local clampedX = math.min(defaultSizeX, vp.X * 0.95 - 40)
    local clampedY = math.min(defaultSizeY, vp.Y * 0.95 - 40)
    local defaultSize = UDim2.new(0, clampedX, 0, clampedY)
    local sidebarWidth = clampedX < 450 and 120 or 160

    local shadow = create("ImageLabel", {
        Parent = gui,
        BackgroundTransparency = 1,
        Image = "rbxassetid://6014261993",
        ImageColor3 = Color3.new(0, 0, 0),
        ImageTransparency = 1,
        ScaleType = Enum.ScaleType.Slice,
        SliceCenter = Rect.new(49, 49, 450, 450),
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = cfg.Position or UDim2.new(0.5, 0, 0.5, 0),
        Size = defaultSize + UDim2.new(0, 40, 0, 40)
    })

    local scaleObj = create("UIScale", {Parent = shadow, Scale = 0})

    local root = create("Frame", {
        Parent = shadow,
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = UDim2.new(0.5, 0, 0.5, 0),
        Size = UDim2.new(1, -40, 1, -40),
        BackgroundColor3 = self.Theme.Background,
        BackgroundTransparency = 0,
        BorderSizePixel = 0,
        ClipsDescendants = true
    })
    applyCorner(root, 12)
    applyStroke(root, self.Theme.Stroke, 1, 0.5)

    -- Topbar (TextButton absorbs clicks — prevents other UIs dragging alongside)
    local topbar = create("TextButton", {Parent = root, BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 48), Text = "", AutoButtonColor = false})
    makeDraggable(topbar, shadow)

    local titleLbl = create("TextLabel", {
        Parent = topbar, BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 0), Size = UDim2.new(1, -100, 1, 0),
        Font = Enum.Font.GothamBlack, Text = cfg.Title or "NovaUI Premium",
        TextColor3 = self.Theme.Text, TextSize = 16, TextXAlignment = Enum.TextXAlignment.Left
    })

    local controls = create("Frame", {Parent = topbar, BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0), Position = UDim2.new(1, -12, 0, 12), Size = UDim2.new(0, 60, 0, 24)})
    create("UIListLayout", {Parent = controls, FillDirection = Enum.FillDirection.Horizontal, Padding = UDim.new(0, 8), HorizontalAlignment = Enum.HorizontalAlignment.Right})

    local minBtn = create("TextButton", {Parent = controls, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = self.Theme.Surface, Text = "−", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 14})
    applyCorner(minBtn, 6); applyStroke(minBtn, self.Theme.Stroke, 1, 0.5)

    local closeBtn = create("TextButton", {Parent = controls, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = self.Theme.Surface, Text = "×", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Danger, TextSize = 14})
    applyCorner(closeBtn, 6); applyStroke(closeBtn, self.Theme.Stroke, 1, 0.5)

    for _, btn in ipairs({minBtn, closeBtn}) do
        connect(btn.MouseEnter, function() animate(btn, TweenInfo.new(0.15), {BackgroundColor3 = NovaUI.Theme.SurfaceHover}) end)
        connect(btn.MouseLeave, function() animate(btn, TweenInfo.new(0.15), {BackgroundColor3 = NovaUI.Theme.Surface}) end)
    end

    -- Sidebar separator
    create("Frame", {
        Parent = root, Position = UDim2.new(0, sidebarWidth + 16, 0, 8),
        Size = UDim2.new(0, 1, 1, -16), BackgroundColor3 = self.Theme.Stroke, BackgroundTransparency = 0.4, BorderSizePixel = 0
    })

    local sidebar = create("ScrollingFrame", {
        Parent = root, BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 48), Size = UDim2.new(0, sidebarWidth, 1, -60),
        ScrollBarThickness = 0, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y
    })
    create("UIListLayout", {Parent = sidebar, Padding = UDim.new(0, 6), SortOrder = Enum.SortOrder.LayoutOrder})

    local contentHolder = create("Frame", {
        Parent = root, BackgroundTransparency = 1,
        Position = UDim2.new(0, sidebarWidth + 24, 0, 48),
        Size = UDim2.new(1, -(sidebarWidth + 36), 1, -60),
        ClipsDescendants = true
    })

    local minimized = false
    connect(minBtn.MouseButton1Click, function()
        minimized = not minimized
        animate(shadow, TweenInfo.new(0.4, Enum.EasingStyle.Exponential), {Size = minimized and UDim2.new(0, clampedX, 0, 48) + UDim2.new(0, 40, 0, 40) or defaultSize + UDim2.new(0, 40, 0, 40)})
        contentHolder.Visible = not minimized
        sidebar.Visible = not minimized
    end)

    connect(closeBtn.MouseButton1Click, function() NovaUI:Toggle(false) end)

    -- Toggle button: circular with pulsing glow ring
    if cfg.UseToggleButton ~= false then
        local btn = create("TextButton", {
            Parent = gui, Size = UDim2.new(0, 48, 0, 48), Position = UDim2.new(0, 20, 0.5, 0),
            BackgroundColor3 = self.Theme.Surface, Text = cfg.ToggleButtonText or "UI",
            Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 13
        })
        applyCorner(btn, 24)
        local glowStroke = applyStroke(btn, self.Theme.Accent, 2, 0.7)
        trackTheme("Accent", glowStroke, "Color")

        -- Breathing glow pulse
        local pulsing = true
        task.spawn(function()
            while pulsing do
                animate(glowStroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.1})
                task.wait(1.4)
                if not pulsing then break end
                animate(glowStroke, TweenInfo.new(1.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.85})
                task.wait(1.4)
            end
        end)

        connect(btn.MouseEnter, function()
            animate(btn, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(0, 54, 0, 54)})
            animate(glowStroke, TweenInfo.new(0.2), {Transparency = 0})
        end)
        connect(btn.MouseLeave, function()
            animate(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 48, 0, 48)})
        end)
        connect(btn.MouseButton1Down, function() animate(btn, TweenInfo.new(0.1), {Size = UDim2.new(0, 42, 0, 42)}) end)
        connect(btn.MouseButton1Up, function() animate(btn, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 48, 0, 48)}) end)

        makeDraggable(btn, btn)
        connect(btn.MouseButton1Click, function() NovaUI:Toggle() end)
        self.ToggleButton = btn
    end

    self.MainFrame = shadow
    self.MainScale = scaleObj
    self.CurrentWindow = {
        Root = root, Sidebar = sidebar, Content = contentHolder,
        Shadow = shadow, DefaultSize = defaultSize, Tabs = {}, SelectedTab = nil,
        TitleLabel = titleLbl
    }
    setmetatable(self.CurrentWindow, {__index = WindowMethods})
    return self.CurrentWindow
end

function WindowMethods:SetTitle(text)
    if self.TitleLabel then self.TitleLabel.Text = text or "" end
end

function WindowMethods:CreateTab(cfg)
    local tabBtn = create("TextButton", {
        Parent = self.Sidebar, Size = UDim2.new(1, 0, 0, 36),
        BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 1,
        Text = (cfg.Icon and cfg.Icon .. "  " or "") .. (cfg.Name or "Tab"),
        Font = Enum.Font.GothamSemibold, TextColor3 = NovaUI.Theme.Muted, TextSize = 13, AutoButtonColor = false
    })
    applyCorner(tabBtn, 8)
    local btnStroke = applyStroke(tabBtn, NovaUI.Theme.Stroke, 1, 1)

    -- Active left-edge indicator bar
    local indicator = create("Frame", {
        Parent = tabBtn, Position = UDim2.new(0, 0, 0.5, -10),
        Size = UDim2.new(0, 3, 0, 0), BackgroundColor3 = NovaUI.Theme.Accent, BorderSizePixel = 0
    })
    applyCorner(indicator, 2)
    trackTheme("Accent", indicator, "BackgroundColor3")

    local page = create("ScrollingFrame", {
        Parent = self.Content, Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1, Visible = false,
        Position = UDim2.new(0.06, 0, 0, 0),
        ScrollBarThickness = 2, ScrollBarImageColor3 = NovaUI.Theme.Accent,
        CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y
    })
    create("UIListLayout", {Parent = page, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder})
    create("UIPadding", {Parent = page, PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12), PaddingRight = UDim.new(0, 6)})

    local tab = {Button = tabBtn, Page = page, Sections = {}, Indicator = indicator}
    table.insert(self.Tabs, tab)
    setmetatable(tab, {__index = TabMethods})

    local function selectTab()
        if self.SelectedTab and self.SelectedTab ~= tab then
            local prev = self.SelectedTab
            -- Hide old page immediately so no overlap glitch
            prev.Page.Visible = false
            prev.Page.Position = UDim2.new(0, 0, 0, 0)
            animate(prev.Button, TweenInfo.new(0.25), {BackgroundTransparency = 1, TextColor3 = NovaUI.Theme.Muted})
            animate(prev.Button.UIStroke, TweenInfo.new(0.25), {Transparency = 1})
            animate(prev.Indicator, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 3, 0, 0)})
        end
        self.SelectedTab = tab
        -- Slide new page in from a slight right offset
        page.Position = UDim2.new(0.05, 0, 0, 0)
        page.Visible = true
        animate(page, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)})
        animate(tabBtn, TweenInfo.new(0.25), {BackgroundTransparency = 0, TextColor3 = NovaUI.Theme.Text})
        animate(btnStroke, TweenInfo.new(0.25), {Transparency = 0})
        animate(indicator, TweenInfo.new(0.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 3, 0, 20)})
    end

    connect(tabBtn.MouseButton1Click, selectTab)
    if not self.SelectedTab then selectTab() end
    return tab
end

