function WindowMethods:CreateTab(cfg)
    local tabBtn = create("TextButton", {
        Parent = self.Sidebar, Size = UDim2.new(1, 0, 0, 36), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 1,
        Text = cfg.Name or "Tab", Font = Enum.Font.GothamSemibold, TextColor3 = NovaUI.Theme.Muted, TextSize = 13, AutoButtonColor = false
    })
    applyCorner(tabBtn, 8)
    local btnStroke = applyStroke(tabBtn, NovaUI.Theme.Stroke, 1, 1)

    local page = create("ScrollingFrame", {
        Parent = self.Content, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Visible = false,
        ScrollBarThickness = 2, ScrollBarImageColor3 = NovaUI.Theme.Accent, CanvasSize = UDim2.new(0, 0, 0, 0), AutomaticCanvasSize = Enum.AutomaticSize.Y
    })
    create("UIListLayout", {Parent = page, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder})
    create("UIPadding", {Parent = page, PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 12), PaddingRight = UDim.new(0, 6)})

    local tab = {Button = tabBtn, Page = page, Sections = {}}
    table.insert(self.Tabs, tab)
    setmetatable(tab, {__index = TabMethods})

    local function selectTab()
        if self.SelectedTab then
            self.SelectedTab.Page.Visible = false
            animate(self.SelectedTab.Button, TweenInfo.new(0.3), {BackgroundTransparency = 1, TextColor3 = NovaUI.Theme.Muted})
            animate(self.SelectedTab.Button.UIStroke, TweenInfo.new(0.3), {Transparency = 1})
        end
        self.SelectedTab = tab
        tab.Page.Visible = true
        animate(tab.Button, TweenInfo.new(0.3), {BackgroundTransparency = 0, TextColor3 = NovaUI.Theme.Text})
        animate(btnStroke, TweenInfo.new(0.3), {Transparency = 0})
    end

    connect(tabBtn.MouseButton1Click, selectTab)
    if not self.SelectedTab then selectTab() end
    return tab
end

