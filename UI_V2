    local btn = create("TextButton", {Parent = row, Position = UDim2.new(1, -112, 0.5, -14), Size = UDim2.new(0, 100, 0, 28), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0, Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Accent, Text = bound.Name, TextSize = 12})
    applyCorner(btn, 6)
    applyStroke(btn, NovaUI.Theme.Stroke, 1, 0.5)

    local listening = false
    connect(btn.MouseButton1Click, function()
        listening = true
        btn.Text = "..."
    end)
    connect(UserInputService.InputBegan, function(inp, gp)
        if listening and inp.KeyCode ~= Enum.KeyCode.Unknown then
            listening = false
            bound = inp.KeyCode
            btn.Text = bound.Name
            if cfg.Flag then NovaUI.Flags[cfg.Flag] = bound.Name end
            if cfg.Callback then task.spawn(cfg.Callback, bound) end
        elseif not listening and inp.KeyCode == bound and not gp then
            if cfg.Pressed then task.spawn(cfg.Pressed) end
        end
    end)
end

function SectionMethods:AddColorPicker(cfg)
    local palette = cfg.Options or {Color3.fromRGB(120, 90, 255), Color3.fromRGB(80, 210, 130), Color3.fromRGB(250, 150, 70), Color3.fromRGB(230, 90, 90), Color3.fromRGB(250, 250, 255)}
    local selected = cfg.Default or palette[1]
    local row = makeRow(self.Holder, 42)
    
    local title = create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -160, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Color", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local swatches = create("Frame", {Parent = row, Position = UDim2.new(1, -150, 0.5, -12), Size = UDim2.new(0, 140, 0, 24), BackgroundTransparency = 1})
    local list = create("UIListLayout", {Parent = swatches, Padding = UDim.new(0, 6), FillDirection = Enum.FillDirection.Horizontal, HorizontalAlignment = Enum.HorizontalAlignment.Right})
    
    local function setColor(c)
        selected = c
        if cfg.ApplyAccent then NovaUI:SetTheme({Accent = c}) end
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = {c.R, c.G, c.B} end
        if cfg.Callback then task.spawn(cfg.Callback, c) end
    end

    for _, c in ipairs(palette) do
        local btn = create("TextButton", {Parent = swatches, Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = c, Text = ""})
        applyCorner(btn, 12)
        applyStroke(btn, NovaUI.Theme.Stroke, 1, 0.3)
        connect(btn.MouseButton1Click, function() animate(btn, TweenInfo.new(0.1, Enum.EasingStyle.Bounce), {Size = UDim2.new(0, 20, 0, 20)}); task.wait(0.1); animate(btn, TweenInfo.new(0.2), {Size = UDim2.new(0, 24, 0, 24)}); setColor(c) end)
    end
    return {Set = setColor, Get = function() return selected end}
end

function SectionMethods:AddParagraph(cfg)
    local row = makeRow(self.Holder, 0)
    row.AutomaticSize = Enum.AutomaticSize.Y
    create("UIPadding", {Parent = row, PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10), PaddingLeft = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})
    create("UIListLayout", {Parent = row, Padding = UDim.new(0, 4)})
    
    local title = create("TextLabel", {Parent = row, Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1, Text = cfg.Title or "Paragraph", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local body = create("TextLabel", {Parent = row, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Text = cfg.Content or "", Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 12, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Top})
    
    return {Set = function(t, c) if t then title.Text = t end if c then body.Text = c end end}
end

function NovaUI:Notify(cfg)
    local gui = self:_ensureGui()
    
    local holder = gui:FindFirstChild("NotifyHolder")
    if not holder then
        holder = create("Frame", {Parent = gui, Name = "NotifyHolder", BackgroundTransparency = 1, Size = UDim2.new(0, 300, 1, -40), Position = UDim2.new(1, -20, 0, 20), AnchorPoint = Vector2.new(1, 0)})
        create("UIListLayout", {Parent = holder, Padding = UDim.new(0, 8), VerticalAlignment = Enum.VerticalAlignment.Bottom})
    end

    local msg = create("Frame", {Parent = holder, Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = self.Theme.Surface, BackgroundTransparency = 0, Position = UDim2.new(1, 50, 0, 0)})
    applyCorner(msg, 10)
    applyStroke(msg, self.Theme.Stroke, 1, 0.3)
    
    create("UIPadding", {Parent = msg, PaddingLeft = UDim.new(0, 14), PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12), PaddingRight = UDim.new(0, 12)})
    create("TextLabel", {Parent = msg, Size = UDim2.new(1, 0, 0, 18), BackgroundTransparency = 1, Text = cfg.Title or "Notification", Font = Enum.Font.GothamBold, TextColor3 = self.Theme.Text, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left})
    create("TextLabel", {Parent = msg, Position = UDim2.new(0, 0, 0, 20), Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Text = cfg.Content or "", Font = Enum.Font.Gotham, TextColor3 = self.Theme.Muted, TextSize = 13, TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left})
    
    local accent = create("Frame", {Parent = msg, Position = UDim2.new(0, -14, 0, 0), Size = UDim2.new(0, 3, 1, 0), BackgroundColor3 = self.Theme.Accent})
    applyCorner(accent, 4)

    animate(msg, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)})
    task.delay(cfg.Duration or 3, function()
        animate(msg, TweenInfo.new(0.3, Enum.EasingStyle.Sine, Enum.EasingDirection.In), {Position = UDim2.new(1, 50, 0, 0), BackgroundTransparency = 1})
        for _, v in ipairs(msg:GetChildren()) do if v:IsA("TextLabel") then animate(v, TweenInfo.new(0.3), {TextTransparency = 1}) end end
        task.wait(0.3)
        msg:Destroy()
    end)
end


function NovaUI:Init()
    if self.MainScale then
        self.Hidden = false
        animate(self.MainScale, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Scale = 1
        })
    end
end

return NovaUI
