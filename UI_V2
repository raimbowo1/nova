function SectionMethods:AddToggle(cfg)
    local row = makeRow(self.Holder, 42)
    local label = create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(1, -70, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Toggle", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    
    local box = create("Frame", {Parent = row, Position = UDim2.new(1, -54, 0.5, -12), Size = UDim2.new(0, 42, 0, 24), BackgroundColor3 = NovaUI.Theme.Background})
    applyCorner(box, 12)
    applyStroke(box, NovaUI.Theme.Stroke, 1)

    local knob = create("Frame", {Parent = box, Position = UDim2.new(0, 2, 0.5, -10), Size = UDim2.new(0, 20, 0, 20), BackgroundColor3 = NovaUI.Theme.Text})
    applyCorner(knob, 10)

    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
    
    local state = cfg.Default or false
    local function setToggle(v, skipCallback)
        state = v
        animate(box, TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.Background})
        animate(knob, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Position = state and UDim2.new(1, -22, 0.5, -10) or UDim2.new(0, 2, 0.5, -10)})
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = state end
        if not skipCallback and cfg.Callback then task.spawn(cfg.Callback, state) end
    end
    
    connect(btn.MouseButton1Click, function() setToggle(not state) end)
    setToggle(state, true)
    return {Set = setToggle, Get = function() return state end}
end

function SectionMethods:AddSlider(cfg)
    local min, max, inc = cfg.Min or 0, cfg.Max or 100, cfg.Increment or 1
    local row = makeRow(self.Holder, 54)
    
    local title = create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 8), Size = UDim2.new(1, -24, 0, 16), BackgroundTransparency = 1, Text = cfg.Name or "Slider", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local valLbl = create("TextLabel", {Parent = row, Position = UDim2.new(1, -62, 0, 8), Size = UDim2.new(0, 50, 0, 16), BackgroundTransparency = 1, Text = tostring(cfg.Default or min), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Muted, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right})
    
    local bar = create("Frame", {Parent = row, Position = UDim2.new(0, 12, 0, 34), Size = UDim2.new(1, -24, 0, 6), BackgroundColor3 = NovaUI.Theme.Surface})
    applyCorner(bar, 3)
    
    local fill = create("Frame", {Parent = bar, Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = NovaUI.Theme.Accent})
    applyCorner(fill, 3)

    local knob = create("Frame", {Parent = fill, AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.new(0, 14, 0, 14), BackgroundColor3 = NovaUI.Theme.Text})
    applyCorner(knob, 7)

    local function setVal(v, skip)
        v = math.clamp(math.floor(v / inc + 0.5) * inc, min, max)
        local pct = (max == min) and 0 or (v - min) / (max - min)
        animate(fill, TweenInfo.new(0.1), {Size = UDim2.new(pct, 0, 1, 0)})
        valLbl.Text = tostring(v) .. (cfg.Suffix or "")
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = v end
        if not skip and cfg.Callback then task.spawn(cfg.Callback, v) end
    end

    local dragging = false
    local function update(input)
        local pct = math.clamp((input.Position.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        setVal(min + pct * (max - min))
    end
    
    local hitBox = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = ""})
    connect(hitBox.InputBegan, function(inp) if inp.UserInputType.Name:find("MouseButton1") or inp.UserInputType == Enum.UserInputType.Touch then dragging = true; animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0, 18, 0, 18)}); update(inp) end end)
    connect(hitBox.InputEnded, function(inp) if inp.UserInputType.Name:find("MouseButton1") or inp.UserInputType == Enum.UserInputType.Touch then dragging = false; animate(knob, TweenInfo.new(0.2), {Size = UDim2.new(0, 14, 0, 14)}) end end)
    connect(UserInputService.InputChanged, function(inp) if dragging and (inp.UserInputType.Name:find("MouseMovement") or inp.UserInputType == Enum.UserInputType.Touch) then update(inp) end end)

    setVal(cfg.Default or min, true)
    return {Set = setVal}
end

function SectionMethods:AddDropdown(cfg)
    local options = cfg.Options or {}
    local selected = cfg.Default or options[1] or "..."
    local row = makeRow(self.Holder, 38)
    
    local title = create("TextLabel", {Parent = row, Position = UDim2.new(0, 12, 0, 0), Size = UDim2.new(0.5, 0, 0, 38), BackgroundTransparency = 1, Text = cfg.Name or "Dropdown", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Text, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})
    local valLbl = create("TextLabel", {Parent = row, Position = UDim2.new(0.5, 0, 0, 0), Size = UDim2.new(0.5, -30, 0, 38), BackgroundTransparency = 1, Text = tostring(selected), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Accent, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Right})
    local arrow = create("TextLabel", {Parent = row, Position = UDim2.new(1, -26, 0, 0), Size = UDim2.new(0, 26, 0, 38), BackgroundTransparency = 1, Text = "v", Font = Enum.Font.GothamBold, TextColor3 = NovaUI.Theme.Muted, TextSize = 14})
    
    local ddlBase = create("Frame", {Parent = row, Position = UDim2.new(0, 0, 0, 38), Size = UDim2.new(1, 0, 0, 0), BackgroundColor3 = NovaUI.Theme.Background, BackgroundTransparency = 0, ClipsDescendants = true})
    local listLayout = create("UIListLayout", {Parent = ddlBase, Padding = UDim.new(0, 4)})
    
    local open = false
    local function toggleMenu()
        open = not open
        arrow.Text = open and "^" or "v"
        animate(row, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and (42 + (#options * 32)) or 38)})
        animate(ddlBase, TweenInfo.new(0.3, Enum.EasingStyle.Quint), {Size = UDim2.new(1, 0, 0, open and (#options * 32) or 0)})
    end

    local btn = create("TextButton", {Parent = row, Size = UDim2.new(1, 0, 0, 38), BackgroundTransparency = 1, Text = ""})
    connect(btn.MouseButton1Click, toggleMenu)

    local function buildOpts()
        for _, c in ipairs(ddlBase:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        for _, opt in ipairs(options) do
            local oBtn = create("TextButton", {Parent = ddlBase, Size = UDim2.new(1, 0, 0, 28), BackgroundColor3 = NovaUI.Theme.Surface, BackgroundTransparency = 0, Text = tostring(opt), Font = Enum.Font.Gotham, TextColor3 = NovaUI.Theme.Text, TextSize = 12})
            applyCorner(oBtn, 6)
            connect(oBtn.MouseButton1Click, function()
                selected = opt
                valLbl.Text = tostring(opt)
                toggleMenu()
                if cfg.Flag then NovaUI.Flags[cfg.Flag] = opt end
                if cfg.Callback then task.spawn(cfg.Callback, opt) end
            end)
        end
    end
    buildOpts()
    return {Refresh = function(newOpts) options = newOpts or {}; buildOpts() end}
end

