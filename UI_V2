    local function setVal(v, skip)
        v = math.clamp(math.floor(v / inc + 0.5) * inc, min, max)
        animate(fill, TweenInfo.new(0.1), {Size = UDim2.new((v - min) / (max - min), 0, 1, 0)})
        valLbl.Text = tostring(v) .. (cfg.ValueName or "")
