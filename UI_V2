    local lbl = create("TextLabel", {Parent = tabBtn, Position = UDim2.new(0, 36, 0, 0), Size = UDim2.new(1, -36, 1, 0), BackgroundTransparency = 1, Text = cfg.Name or "Tab", Font = Enum.Font.GothamSemibold, TextColor3 = NovaUI.Theme.Muted, TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left})

    local indicator = create("Frame", { Parent = tabBtn, Position = UDim2.new(0, 0, 0.5, -10), Size = UDim2.new(0, 3, 0, 0), BackgroundColor3 = NovaUI.Theme.Accent, BorderSizePixel = 0 }); applyCorner(indicator, 2); trackTheme("Accent", indicator, "BackgroundColor3")

    local page = create("ScrollingFrame", { Parent = self.Content, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Visible = false, Position = UDim2.new(0.05, 0, 0, 0), ScrollBarThickness = 2, ScrollBarImageColor3 = NovaUI.Theme.Accent, AutomaticCanvasSize = Enum.AutomaticSize.Y })
    create("UIListLayout", {Parent = page, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder}); trackTheme("Accent", page, "ScrollBarImageColor3")
    create("UIPadding", {Parent = page, PaddingTop = UDim.new(0, 2), PaddingBottom = UDim.new(0, 12), PaddingRight = UDim.new(0, 6)})

    local tab = {Button = tabBtn, Page = page, Sections = {}, Indicator = indicator, LabelText = lbl}
    table.insert(self.Tabs, tab); setmetatable(tab, {__index = TabMethods})

    local function selectTab()
        if self.SelectedTab and self.SelectedTab ~= tab then
            local prev = self.SelectedTab
            prev.Page.Visible = false; prev.Page.Position = UDim2.new(0, 0, 0, 0)
            animate(prev.Button, TweenInfo.new(0.25), {BackgroundTransparency = 1})
            animate(prev.Button:FindFirstChildOfClass("TextLabel"), TweenInfo.new(0.25), {TextColor3 = NovaUI.Theme.Muted})
            animate(prev.Indicator, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = UDim2.new(0, 3, 0, 0)})
        end
        self.SelectedTab = tab
        page.Position = UDim2.new(0.03, 0, 0, 0); page.Visible = true
        animate(page, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(0, 0, 0, 0)})
        animate(tabBtn, TweenInfo.new(0.25), {BackgroundTransparency = 0})
        animate(lbl, TweenInfo.new(0.25), {TextColor3 = NovaUI.Theme.Text})
        animate(icn, TweenInfo.new(0.25), {TextColor3 = NovaUI.Theme.Text})
        animate(indicator, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0, 3, 0, 20)})
    end
    tab.Select = selectTab
    connect(tabBtn.MouseButton1Click, selectTab)
    if not self.SelectedTab then selectTab() end
    return tab
end

function WindowMethods:CreatePlayerTab(cfg)
    local tab = self:CreateTab({ Name = cfg.Name or "Players", Icon = cfg.Icon or "👥" })
    local actions = cfg.Actions or {}
    local holder = tab.Page
    
    local function reload()
        for _, c in ipairs(holder:GetChildren()) do if c:IsA("Frame") then c:Destroy() end end
        for _, plr in ipairs(game:GetService("Players"):GetPlayers()) do
