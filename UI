-- NovaUI
-- A lightweight Roblox UI library designed for broad compatibility.
-- Goals:
--   * Avoid executor-specific hard dependencies
--   * Work in Studio, live Roblox, and common executors
--   * Similar workflow to Orion-style libraries, but original implementation
--
-- API:
--   local NovaUI = loadstring(game:HttpGet("..."))()
--   local Window = NovaUI:CreateWindow({Title="Demo", SaveConfig=false})
--   local Tab = Window:CreateTab({Name="Main"})
--   local Section = Tab:CreateSection({Name="General"})
--   Section:AddLabel("Hello")
--   Section:AddButton({Name="Click", Callback=function() end})
--   Section:AddToggle({Name="Enabled", Default=false, Callback=function(v) end})
--   Section:AddSlider({Name="Speed", Min=0, Max=100, Default=25, Increment=1, Callback=function(v) end})
--   Section:AddDropdown({Name="Mode", Options={"A","B"}, Default="A", Callback=function(v) end})
--   Section:AddTextbox({Name="Input", Placeholder="Type...", Callback=function(text) end})
--   Section:AddParagraph({Title="Info", Content="Text here"})
--   NovaUI:Notify({Title="Loaded", Content="NovaUI ready", Duration=4})
--   NovaUI:Init()

