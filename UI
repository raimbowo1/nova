function SectionMethods:AddButton(cfg)
    cfg = cfg or {}
    local row = baseRow(self.Holder, 36)
    local btn = create("TextButton", {
        Parent = row,
        AutoButtonColor = false,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = cfg.Name or "Button",
        TextColor3 = NovaUI.Theme.Text,
        TextSize = 13
    })

    connect(btn.MouseEnter, function()
        animate(row, TweenInfo.new(0.12), {BackgroundColor3 = NovaUI.Theme.SurfaceHover})
    end)
    connect(btn.MouseLeave, function()
        animate(row, TweenInfo.new(0.12), {BackgroundColor3 = NovaUI.Theme.Background})
    end)
    connect(btn.MouseButton1Click, function()
        task.spawn(function()
            if cfg.Callback then cfg.Callback() end
        end)
    end)

    return {
        Set = function(_, v)
            btn.Text = tostring(v)
        end
    }
end

function SectionMethods:AddToggle(cfg)
    cfg = cfg or {}
    local flag = cfg.Flag
    local state = cfg.Default == true

    local row = baseRow(self.Holder, 40)
    local label = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -72, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = cfg.Name or "Toggle",
        TextColor3 = NovaUI.Theme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local box = create("Frame", {
        Parent = row,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.new(0, 42, 0, 22),
        BackgroundColor3 = NovaUI.Theme.Surface,
        BorderSizePixel = 0
    })
    corner(box, 999)
    stroke(box, NovaUI.Theme.Stroke, 1)

    local knob = create("Frame", {
        Parent = box,
        Size = UDim2.new(0, 16, 0, 16),
        Position = UDim2.new(0, 3, 0.5, -8),
        BackgroundColor3 = NovaUI.Theme.Text,
        BorderSizePixel = 0
    })
    corner(knob, 999)

    local click = create("TextButton", {
        Parent = row,
        BackgroundTransparency = 1,
        Text = "",
        Size = UDim2.new(1, 0, 1, 0)
    })

    local toggle = {}
    function toggle:Set(v)
        state = not not v
        animate(box, TweenInfo.new(0.15), {BackgroundColor3 = state and NovaUI.Theme.Accent or NovaUI.Theme.Surface})
        animate(knob, TweenInfo.new(0.15), {Position = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)})
        if flag then NovaUI.Flags[flag] = state end
        if cfg.Callback then task.spawn(cfg.Callback, state) end
    end

    connect(click.MouseButton1Click, function()
        toggle:Set(not state)
    end)

    toggle:Set(state)
    return toggle
end

