end

local function baseRow(parent, height)
    local row = create("Frame", {
        Parent = parent,
        BackgroundColor3 = NovaUI.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, height or 36)
    })
    corner(row, 10)
    stroke(row, NovaUI.Theme.Stroke, 1)
    return row
end

function SectionMethods:AddLabel(text)
    local row = baseRow(self.Holder, 34)
    local lbl = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(1, -24, 1, 0),
