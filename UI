function NovaUI:CreateWindow(cfg)
    cfg = cfg or {}
    self.SaveConfig = cfg.SaveConfig or false
    self.ConfigFolder = cfg.ConfigFolder or self.ConfigFolder

    if self.SaveConfig and saveFileAvailable() and not isfolder(self.ConfigFolder) then
        makefolder(self.ConfigFolder)
    end

    local gui = self:_ensureGui()

    local root = create("Frame", {
        Parent = gui,
        Name = "MainWindow",
        AnchorPoint = Vector2.new(0.5, 0.5),
        Position = cfg.Position or UDim2.new(0.5, 0, 0.5, 0),
        Size = cfg.Size or UDim2.new(0, 680, 0, 420),
        BackgroundColor3 = self.Theme.Background,
        BorderSizePixel = 0
    })
    corner(root, 14)
    stroke(root, self.Theme.Stroke, 1)
    create("UIScale", {Parent = root, Scale = cfg.UIScale or 1})

    local topbar = create("Frame", {
        Parent = root,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 46)
    })
    pad(topbar, 14, 14, 10, 0)

    local title = create("TextLabel", {
        Parent = topbar,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -120, 1, 0),
        Font = Enum.Font.GothamBlack,
        Text = cfg.Title or cfg.Name or "NovaUI",
        TextColor3 = self.Theme.Text,
        TextSize = 18,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local controls = create("Frame", {
        Parent = topbar,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(1, 0, 0, 0),
        Size = UDim2.new(0, 94, 0, 30)
    })
    list(controls, 6, true)

    local function makeControl(txt)
        local b = create("TextButton", {
            Parent = controls,
            AutoButtonColor = false,
            Size = UDim2.new(0, 44, 1, 0),
            BackgroundColor3 = self.Theme.Surface,
            BorderSizePixel = 0,
            Font = Enum.Font.GothamBold,
            Text = txt,
            TextColor3 = self.Theme.Text,
            TextSize = 14
        })
        corner(b, 10)
        stroke(b, self.Theme.Stroke, 1)
        return b
    end

    local minimize = makeControl("–")
    local close = makeControl("×")

    local divider = create("Frame", {
        Parent = root,
        BackgroundColor3 = self.Theme.Stroke,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 0, 0, 46),
        Size = UDim2.new(1, 0, 0, 1)
    })

    local sidebar = create("ScrollingFrame", {
        Parent = root,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 47),
        Size = UDim2.new(0, 170, 1, -47),
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = self.Theme.Stroke,
        AutomaticCanvasSize = Enum.AutomaticSize.Y
    })
    pad(sidebar, 10, 10, 12, 12)
    list(sidebar, 8)

    local content = create("Frame", {
        Parent = root,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 171, 0, 47),
        Size = UDim2.new(1, -171, 1, -47)
    })

    local sideDivider = create("Frame", {
        Parent = root,
        BackgroundColor3 = self.Theme.Stroke,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 170, 0, 47),
        Size = UDim2.new(0, 1, 1, -47)
    })

    makeDraggable(topbar, root)

    local minimized = false
    connect(minimize.MouseButton1Click, function()
        minimized = not minimized
        content.Visible = not minimized
        sidebar.Visible = not minimized
        sideDivider.Visible = not minimized
        animate(root, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {
            Size = minimized and UDim2.new(0, 320, 0, 46) or (cfg.Size or UDim2.new(0, 680, 0, 420))
        })
    end)

    connect(close.MouseButton1Click, function()
        NovaUI:Toggle(false)
        if NovaUI.ToggleButton then
            NovaUI.ToggleButton.Visible = true
        end
    end)

    connect(UserInputService.InputBegan, function(input, gp)
        if gp then return end
        if input.KeyCode == (cfg.ToggleKey or Enum.KeyCode.RightShift) then
            NovaUI:Toggle()
        end
    end)

    if cfg.UseToggleButton ~= false then
        local btn = create("TextButton", {
            Parent = gui,
            Name = "NovaToggle",
            AutoButtonColor = false,
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 16, 0.5, 0),
            Size = UDim2.new(0, 46, 0, 46),
            BackgroundColor3 = self.Theme.Surface,
            BorderSizePixel = 0,
            Font = Enum.Font.GothamBlack,
            Text = cfg.ToggleButtonText or "UI",
            TextColor3 = self.Theme.Text,
            TextSize = 14
        })
        corner(btn, 999)
        stroke(btn, self.Theme.Stroke, 1)
        makeDraggable(btn, btn)
        connect(btn.MouseButton1Click, function()
            NovaUI:Toggle()
        end)
        self.ToggleButton = btn
    end

    self.MainFrame = root
    self.CurrentWindow = {
        Root = root,
        Sidebar = sidebar,
        Content = content,
        Tabs = {},
        SelectedTab = nil
    }
    setmetatable(self.CurrentWindow, {__index = WindowMethods})
    return self.CurrentWindow
end

function WindowMethods:CreateTab(cfg)
    cfg = cfg or {}
    local name = cfg.Name or "Tab"

    local tabBtn = create("TextButton", {
        Parent = self.Sidebar,
        AutoButtonColor = false,
        BackgroundColor3 = NovaUI.Theme.Surface,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 34),
        Font = Enum.Font.GothamSemibold,
        Text = name,
        TextColor3 = NovaUI.Theme.Muted,
        TextSize = 14
    })
    corner(tabBtn, 10)
    stroke(tabBtn, NovaUI.Theme.Stroke, 1)

    local page = create("ScrollingFrame", {
        Parent = self.Content,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 1, 0),
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = NovaUI.Theme.Stroke,
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        Visible = false
    })
    pad(page, 12, 12, 12, 12)
    list(page, 10)

    local tab = {
        Button = tabBtn,
        Page = page,
        Sections = {}
    }
    setmetatable(tab, {__index = TabMethods})
    table.insert(self.Tabs, tab)

    local function select()
        if self.SelectedTab then
            self.SelectedTab.Page.Visible = false
            self.SelectedTab.Button.BackgroundColor3 = NovaUI.Theme.Surface
            self.SelectedTab.Button.TextColor3 = NovaUI.Theme.Muted
        end
        self.SelectedTab = tab
        tab.Page.Visible = true
        tab.Button.BackgroundColor3 = NovaUI.Theme.Accent
        tab.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    end

    connect(tabBtn.MouseButton1Click, select)

    if not self.SelectedTab then
        select()
    end

    return tab
end

