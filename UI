        Font = Enum.Font.Gotham,
        Text = "",
        TextColor3 = NovaUI.Theme.Muted,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right
    })

    local bar = create("Frame", {
        Parent = row,
        BackgroundColor3 = NovaUI.Theme.Surface,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 12, 0, 32),
        Size = UDim2.new(1, -24, 0, 14)
    })
    corner(bar, 999)
    stroke(bar, NovaUI.Theme.Stroke, 1)

    local fill = create("Frame", {
        Parent = bar,
        BackgroundColor3 = NovaUI.Theme.Accent,
        BorderSizePixel = 0,
        Size = UDim2.new(0, 0, 1, 0)
    })
    corner(fill, 999)

    local slider = {}
    function slider:Set(v)
        v = math.clamp(v, min, max)
        v = math.floor(v / inc + 0.5) * inc
        value = v
        local alpha = (v - min) / (max - min)
        fill.Size = UDim2.new(alpha, 0, 1, 0)
        valueLbl.Text = tostring(v) .. (cfg.ValueName and (" " .. cfg.ValueName) or "")
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = v end
        if cfg.Callback then task.spawn(cfg.Callback, v) end
    end

    local function update(posX)
        local alpha = math.clamp((posX - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        slider:Set(min + ((max - min) * alpha))
    end

    connect(bar.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input.Position.X)
        end
    end)
    connect(bar.InputEnded, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    connect(UserInputService.InputChanged, function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input.Position.X)
        end
    end)

    slider:Set(value)
    return slider
end

function SectionMethods:AddDropdown(cfg)
    cfg = cfg or {}
    local options = cfg.Options or {}
    local selected = cfg.Default or options[1] or "..."
    local open = false

    local row = create("Frame", {
        Parent = self.Holder,
        BackgroundColor3 = NovaUI.Theme.Background,
        BorderSizePixel = 0,
        Size = UDim2.new(1, 0, 0, 40),
        ClipsDescendants = true
    })
    corner(row, 10)
    stroke(row, NovaUI.Theme.Stroke, 1)

    local header = create("TextButton", {
        Parent = row,
        AutoButtonColor = false,
        BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 40),
        Text = ""
    })

    local title = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.5, 0, 0, 40),
        Font = Enum.Font.GothamBold,
        Text = cfg.Name or "Dropdown",
        TextColor3 = NovaUI.Theme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local current = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0.5, 0, 0, 0),
        Size = UDim2.new(0.5, -32, 0, 40),
        Font = Enum.Font.Gotham,
        Text = tostring(selected),
        TextColor3 = NovaUI.Theme.Muted,
        TextSize = 12,
        TextXAlignment = Enum.TextXAlignment.Right
    })

    local arrow = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.new(0, 16, 0, 16),
        Font = Enum.Font.GothamBold,
        Text = "˅",
        TextColor3 = NovaUI.Theme.Muted,
        TextSize = 14
    })

    local listHolder = create("Frame", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 8, 0, 44),
        Size = UDim2.new(1, -16, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y
    })
    list(listHolder, 6)

    local dropdown = {Options = options}

    local function rebuild()
        for _, child in ipairs(listHolder:GetChildren()) do
            if child:IsA("TextButton") then child:Destroy() end
        end
        for _, opt in ipairs(options) do
            local btn = create("TextButton", {
                Parent = listHolder,
                AutoButtonColor = false,
                BackgroundColor3 = NovaUI.Theme.Surface,
                BorderSizePixel = 0,
                Size = UDim2.new(1, 0, 0, 30),
                Font = Enum.Font.Gotham,
                Text = tostring(opt),
                TextColor3 = NovaUI.Theme.Text,
                TextSize = 12
            })
            corner(btn, 8)
            stroke(btn, NovaUI.Theme.Stroke, 1)
            connect(btn.MouseButton1Click, function()
                dropdown:Set(opt)
                open = false
                row.Size = UDim2.new(1, 0, 0, 40)
                arrow.Text = "˅"
            end)
        end
    end

    function dropdown:Set(v)
        selected = v
        current.Text = tostring(v)
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = v end
        if cfg.Callback then task.spawn(cfg.Callback, v) end
    end

    function dropdown:Refresh(newOptions, keepValue)
        options = newOptions or {}
        self.Options = options
        rebuild()
        if not keepValue then
            selected = options[1] or "..."
            current.Text = tostring(selected)
        end
    end

    connect(header.MouseButton1Click, function()
        open = not open
        arrow.Text = open and "˄" or "˅"
        local extra = open and math.max(0, (#options * 36) + 8) or 0
        row.Size = UDim2.new(1, 0, 0, 40 + extra)
    end)

    rebuild()
    dropdown:Set(selected)
    return dropdown
end

function SectionMethods:AddTextbox(cfg)
    cfg = cfg or {}
    local row = baseRow(self.Holder, 40)
    local title = create("TextLabel", {
        Parent = row,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 12, 0, 0),
        Size = UDim2.new(0.4, 0, 1, 0),
        Font = Enum.Font.GothamBold,
        Text = cfg.Name or "Textbox",
        TextColor3 = NovaUI.Theme.Text,
        TextSize = 13,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local box = create("TextBox", {
        Parent = row,
        BackgroundColor3 = NovaUI.Theme.Surface,
        BorderSizePixel = 0,
        AnchorPoint = Vector2.new(1, 0.5),
        Position = UDim2.new(1, -12, 0.5, 0),
        Size = UDim2.new(0, 180, 0, 26),
        Font = Enum.Font.Gotham,
        PlaceholderText = cfg.Placeholder or "Type here",
        Text = cfg.Default or "",
        ClearTextOnFocus = false,
        TextColor3 = NovaUI.Theme.Text,
        PlaceholderColor3 = NovaUI.Theme.Muted,
        TextSize = 12
    })
    corner(box, 8)
    stroke(box, NovaUI.Theme.Stroke, 1)

    connect(box.FocusLost, function()
        if cfg.Flag then NovaUI.Flags[cfg.Flag] = box.Text end
        if cfg.Callback then task.spawn(cfg.Callback, box.Text) end
        if cfg.TextDisappear then
            box.Text = ""
        end
    end)

    return {
        Set = function(_, v)
            box.Text = tostring(v)
        end,
        Get = function()
            return box.Text
        end
    }
end

function NovaUI:Init()
    self:_ensureGui()
    connect(RunService.Stepped, function()
        if self.ScreenGui and not self.ScreenGui.Parent then
            disconnectAll()
        end
    end)
end

function NovaUI:Destroy()
    disconnectAll()
    if self.ScreenGui then
        pcall(function() self.ScreenGui:Destroy() end)
    end
    self.ScreenGui = nil
    self.MainFrame = nil
    self.ToggleButton = nil
    self.CurrentWindow = nil
end

return NovaUI
